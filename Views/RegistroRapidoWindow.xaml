<!-- REGISTRO_RAPIDO_WINDOW.XAML -->
<Window x:Class="Proyecto_taller.Views.RegistroRapidoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registro Rápido de Trabajo"
        Height="750" Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="6" BlurRadius="28" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource BgCard}"
                    CornerRadius="11,11,0,0" Padding="22,16">
                <Grid>
                    <TextBlock Text="⚡  Registro Rápido de Trabajo"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="✕" Click="CloseButton_Click"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" FontSize="18" Cursor="Hand"
                            Padding="10,4" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,18">
                <StackPanel>
                    <!-- Cliente -->
                    <TextBlock Text="📋 DATOS DEL CLIENTE" Style="{StaticResource SectionTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nombre: *"   Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtNombre"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Apellido: *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtApellido"/>
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Teléfono: *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtTelefono"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Email:"      Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtEmail"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Dirección:" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtDireccion" Text="Sin dirección"/>

                    <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,14" Opacity="0.4"/>

                    <!-- Vehículo -->
                    <TextBlock Text="🚗 DATOS DEL VEHÍCULO" Style="{StaticResource SectionTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Marca: *"  Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtMarca"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Modelo: *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtModelo"/>
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Placa: *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtPlaca"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Año:"     Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtAnio"/>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,14" Opacity="0.4"/>

                    <!-- Trabajo -->
                    <TextBlock Text="🔧 DATOS DEL TRABAJO" Style="{StaticResource SectionTitle}"/>

                    <TextBlock Text="Tipo de Trabajo: *" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="cmbTipoTrabajo" SelectedIndex="0" Foreground="#FF909090">
                        <ComboBoxItem Content="Mecánica"/>
                        <ComboBoxItem Content="Chapería"/>
                        <ComboBoxItem Content="Pintura"/>
                        <ComboBoxItem Content="Electricidad"/>
                        <ComboBoxItem Content="Mantenimiento General"/>
                    </ComboBox>

                    <TextBlock Text="Descripción del Problema: *" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtDescripcion"
                             Height="72" TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Precio Estimado (Bs.):" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtPrecio" Text="0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Fecha Estimada de Entrega:" Style="{StaticResource FormLabel}"/>
                            <DatePicker x:Name="dpFechaEntrega"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Estado Inicial:" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="cmbEstado" SelectedIndex="0">
                        <ComboBoxItem Content="Pendiente"/>
                        <ComboBoxItem Content="En Progreso"/>
                    </ComboBox>

                    <Border Background="{StaticResource AccentMuted}"
                            CornerRadius="6" Padding="12,10" Margin="0,14,0,0">
                        <TextBlock Foreground="{StaticResource AccentLight}"
                                   FontSize="11" TextWrapping="Wrap">
                            <Run Text="ℹ️ "/>
                            <Run Text="Los campos (*) son obligatorios. Los servicios y repuestos se agregan después desde el módulo Trabajos."/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11" Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✕ Cancelar"         Click="CloseButton_Click"   Style="{StaticResource BtnDanger}"/>
                    <Button Content="✅ Registrar Trabajo" Click="RegistrarButton_Click" Style="{StaticResource BtnSuccess}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
