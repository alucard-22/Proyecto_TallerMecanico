<Page x:Class="Proyecto_taller.Views.Usuarios"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:Proyecto_taller.Helpers"
      Title="Administración de Usuarios"
      Background="{StaticResource BgPrimary}">

    <Page.Resources>
        <helpers:StringToVisibilityConverter x:Key="StrToVis"/>
        <helpers:BoolToColorConverter        x:Key="BoolToColor"/>
        <helpers:BoolToTextConverter         x:Key="BoolToText"/>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header / Toolbar ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título + badge -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="8"
                                Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="👤" FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Administración de Usuarios"
                                       Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Gestiona accesos, roles e historial de actividad"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource AccentMuted}"
                            CornerRadius="8" Padding="12,6">
                        <TextBlock Text="🔒  Solo Administradores"
                                   Foreground="{StaticResource AccentLight}"
                                   FontWeight="SemiBold" FontSize="12"/>
                    </Border>
                </Grid>

                <!-- Barra de búsqueda -->
                <Border Grid.Row="2"
                        Background="{StaticResource BgInput}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="12,0,6,0" Opacity="0.5"
                                   Foreground="{StaticResource TextSecondary}"/>
                        <TextBox Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="4,10"
                                 Text="{Binding TextoBusqueda,
                                        UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2"
                                Content="✕"
                                Command="{Binding LimpiarBusquedaCommand}"
                                Background="Transparent"
                                Foreground="{StaticResource TextMuted}"
                                BorderThickness="0" Cursor="Hand"
                                Padding="10,0" FontSize="13"
                                Visibility="{Binding TextoBusqueda,
                                             Converter={StaticResource StrToVis}}"/>
                    </Grid>
                </Border>

                <!-- Filtros por rol / estado -->
                <StackPanel Grid.Row="4" Orientation="Horizontal">
                    <TextBlock Text="Mostrar:"
                               Foreground="{StaticResource TextSecondary}"
                               FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <RadioButton Content="Todos"
                                 IsChecked="{Binding FiltroTodos}"
                                 GroupName="FiltroUsr"
                                 VerticalAlignment="Center"/>
                    <RadioButton Content="Solo activos"
                                 IsChecked="{Binding FiltroActivos}"
                                 GroupName="FiltroUsr"
                                 VerticalAlignment="Center"/>
                    <RadioButton Content="Administradores"
                                 IsChecked="{Binding FiltroAdmins}"
                                 GroupName="FiltroUsr"
                                 VerticalAlignment="Center"/>
                    <RadioButton Content="Empleados"
                                 IsChecked="{Binding FiltroEmpleados}"
                                 GroupName="FiltroUsr"
                                 VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Botones de acción -->
                <StackPanel Grid.Row="6" Orientation="Horizontal">
                    <Button Content="🔄  Actualizar"
                            Command="{Binding CargarUsuariosCommand}"
                            Style="{StaticResource BtnSecondary}"/>
                    <Button Content="➕  Nuevo Usuario"
                            Command="{Binding AgregarUsuarioCommand}"
                            Style="{StaticResource BtnPrimary}"/>
                    <Button Content="✏️  Editar"
                            Command="{Binding EditarUsuarioCommand}"
                            Style="{StaticResource BtnGhost}"
                            ToolTip="Editar nombre completo y rol"/>

                    <Border Width="1" Background="{StaticResource BorderColor}"
                            Margin="8,4" Opacity="0.5"/>

                    <Button Content="📋  Historial"
                            Command="{Binding VerHistorialCommand}"
                            Style="{StaticResource BtnSuccess}"
                            ToolTip="Ver actividad y datos del usuario"/>
                    <Button Content="🔑  Cambiar Contraseña"
                            Command="{Binding CambiarPasswordCommand}"
                            Style="{StaticResource BtnGhost}"/>
                    <Button Content="⚡  Activar/Desactivar"
                            Command="{Binding ActivarDesactivarCommand}"
                            Style="{StaticResource BtnWarning}"/>

                    <Border Width="1" Background="{StaticResource BorderColor}"
                            Margin="8,4" Opacity="0.5"/>

                    <Button Content="🗑️  Eliminar"
                            Command="{Binding EliminarUsuarioCommand}"
                            Style="{StaticResource BtnDanger}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── DataGrid ── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurface}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1">
            <DataGrid ItemsSource="{Binding Usuarios}"
                      SelectedItem="{Binding UsuarioSeleccionado}"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      MouseDoubleClick="DgUsuarios_DoubleClick"
                      Margin="0">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow"
                           BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Activo}" Value="False">
                                <Setter Property="Background"
                                        Value="{StaticResource RowCancelled}"/>
                                <Setter Property="Opacity" Value="0.55"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding UsuarioID}"
                                        Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource AccentLight}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Usuario"
                                        Binding="{Binding NombreUsuario}"
                                        Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Nombre completo"
                                        Binding="{Binding NombreCompleto}"
                                        Width="*"/>

                    <!-- Rol con badge de color -->
                    <DataGridTemplateColumn Header="Rol" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="badgeRol"
                                        CornerRadius="10" Padding="10,3"
                                        HorizontalAlignment="Left"
                                        Margin="6,0"
                                        Background="{StaticResource AccentMuted}">
                                    <TextBlock x:Name="txtRol"
                                               Text="{Binding Rol}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentLight}"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Rol}"
                                                 Value="Administrador">
                                        <Setter TargetName="badgeRol"
                                                Property="Background" Value="#312E6B"/>
                                        <Setter TargetName="txtRol"
                                                Property="Foreground"
                                                Value="{StaticResource AccentLight}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Rol}"
                                                 Value="Empleado">
                                        <Setter TargetName="badgeRol"
                                                Property="Background" Value="#182820"/>
                                        <Setter TargetName="txtRol"
                                                Property="Foreground"
                                                Value="{StaticResource ColorSuccess}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Activo con punto de color -->
                    <DataGridTemplateColumn Header="Estado" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="14,0">
                                    <Border Width="8" Height="8"
                                            CornerRadius="4"
                                            Margin="0,0,6,0"
                                            Background="{Binding Activo,
                                                Converter={StaticResource BoolToColor}}"/>
                                    <TextBlock Text="{Binding Activo,
                                                   Converter={StaticResource BoolToText}}"
                                               FontSize="12"
                                               Foreground="{Binding Activo,
                                                   Converter={StaticResource BoolToColor}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Creación"
                                        Binding="{Binding FechaCreacion, StringFormat=dd/MM/yyyy}"
                                        Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{StaticResource TextMuted}"/>
                                <Setter Property="FontSize" Value="11"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Último acceso"
                                        Binding="{Binding UltimoAcceso,
                                                  StringFormat=dd/MM/yyyy HH:mm}"
                                        Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{StaticResource TextMuted}"/>
                                <Setter Property="FontSize" Value="11"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Columna nueva: último cambio de contraseña -->
                    <DataGridTextColumn Header="Último cambio pass."
                                        Binding="{Binding FechaUltimoCambioPassword,
                                                  StringFormat=dd/MM/yyyy HH:mm}"
                                        Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{StaticResource TextMuted}"/>
                                <Setter Property="FontSize" Value="11"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
