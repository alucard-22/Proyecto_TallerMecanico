<Window x:Class="Proyecto_taller.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Iniciar Sesión - Taller El Choco"
        Height="560" Width="420"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1"
            CornerRadius="14">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgCard}"
                    CornerRadius="13,13,0,0"
                    Padding="30,24">
                <Grid>
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="72" Height="72" CornerRadius="36"
                                HorizontalAlignment="Center" Margin="0,0,0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🔧" FontSize="36"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="TALLER EL CHOCO"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Sistema de Gestión"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12" HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Content="✕"
                            Click="CloseButton_Click"
                            Background="Transparent"
                            Foreground="{StaticResource TextMuted}"
                            BorderThickness="0"
                            FontSize="16" Cursor="Hand"
                            Padding="8,4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- ── Formulario con ScrollViewer para que el panel de error no se corte ── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          MaxHeight="400">
                <StackPanel Margin="32,24,32,28">

                    <TextBlock Text="Iniciar Sesión"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Usuario -->
                    <TextBlock Text="Usuario"
                               Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtUsuario" Margin="0,0,0,14"
                             KeyDown="TxtUsuario_KeyDown"/>

                    <!-- Contraseña -->
                    <TextBlock Text="Contraseña"
                               Style="{StaticResource FormLabel}"/>
                    <PasswordBox x:Name="txtPassword" Margin="0,0,0,10"
                                 KeyDown="TxtPassword_KeyDown"/>

                    <CheckBox x:Name="chkRecordar"
                              Content="Recordar mi sesión"
                              Margin="0,0,0,20"/>

                    <!-- Botón ingresar -->
                    <Button Content="🔐  Ingresar al Sistema"
                            Click="LoginButton_Click"
                            Style="{StaticResource BtnPrimary}"
                            Padding="0,14"
                            FontSize="14"
                            Margin="0"/>

                    <!-- Panel de error — crece automáticamente con el texto -->
                    <Border x:Name="errorPanel"
                            Background="#2D1A1A"
                            BorderBrush="{StaticResource ColorDanger}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,10"
                            Visibility="Collapsed"
                            Margin="0,14,0,0">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <TextBlock Text="⚠️"
                                       FontSize="13"
                                       Margin="0,1,8,0"
                                       VerticalAlignment="Top"/>
                            <TextBlock x:Name="txtError"
                                       FontSize="12"
                                       Foreground="#FCA5A5"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
