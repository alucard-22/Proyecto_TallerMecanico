<UserControl x:Class="Proyecto_taller.Views.Reservas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPrimary}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="38" Height="38" CornerRadius="8" Margin="0,0,12,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6366F1" Offset="0"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="📅" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Gestión de Reservas" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="Administra las citas y reservas de los clientes"
                                   Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Estadísticas rápidas ── -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📋 Hoy" Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtHoy" Text="0"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource AccentLight}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="⏳ Pendientes" Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtPendientes" Text="0"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource ColorWarning}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="✅ Confirmadas" Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtConfirmadas" Text="0"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource ColorSuccess}"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="🔄 En Curso" Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtEnCurso" Text="0"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource ColorInfo}"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="📊 Este Mes" Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtEsteMes" Text="0"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Filtros y búsqueda ── -->
        <Border Grid.Row="4" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Estado:" Foreground="{StaticResource TextSecondary}"
                               FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <RadioButton x:Name="rbTodas"      Content="📋 Todas"      GroupName="FiltroEst" IsChecked="True" Checked="FiltroEstado_Changed" VerticalAlignment="Center"/>
                    <RadioButton x:Name="rbPendientes" Content="⏳ Pendientes" GroupName="FiltroEst" Checked="FiltroEstado_Changed" VerticalAlignment="Center"/>
                    <RadioButton x:Name="rbConfirmadas" Content="✅ Confirmadas" GroupName="FiltroEst" Checked="FiltroEstado_Changed" VerticalAlignment="Center"/>
                    <RadioButton x:Name="rbEnCurso"    Content="🔄 En Curso"   GroupName="FiltroEst" Checked="FiltroEstado_Changed" VerticalAlignment="Center"/>
                    <RadioButton x:Name="rbCompletadas" Content="✓ Completadas" GroupName="FiltroEst" Checked="FiltroEstado_Changed" VerticalAlignment="Center"/>
                    <RadioButton x:Name="rbCanceladas" Content="❌ Canceladas"  GroupName="FiltroEst" Checked="FiltroEstado_Changed" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Búsqueda -->
                <Border Grid.Column="1"
                        Background="{StaticResource BgInput}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1" CornerRadius="6"
                        Width="280">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="13"
                                   VerticalAlignment="Center" Margin="10,0,5,0"
                                   Opacity="0.5" Foreground="{StaticResource TextSecondary}"/>
                        <TextBox Grid.Column="1" x:Name="txtBuscar"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="4,9"
                                 TextChanged="TxtBuscar_TextChanged"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ── Barra de acciones ── -->
        <Border Grid.Row="6" Style="{StaticResource Card}" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <Button Content="🔄 Actualizar"     Click="Actualizar_Click"        Style="{StaticResource BtnSecondary}"/>
                <Button Content="➕ Nueva Reserva"   Click="NuevaReserva_Click"      Style="{StaticResource BtnPrimary}"/>
                <Button Content="✅ Confirmar"        Click="ConfirmarReserva_Click"  Style="{StaticResource BtnSuccess}"/>
                <Button Content="🚀 Iniciar"         Click="IniciarTrabajo_Click"    Style="{StaticResource BtnWarning}"/>
                <Button Content="✓ Completar"        Click="CompletarReserva_Click"  Style="{StaticResource BtnSuccess}"/>
                <Button Content="❌ Cancelar"         Click="CancelarReserva_Click"   Style="{StaticResource BtnDanger}"/>
                <Button Content="📋 Detalles"         Click="VerDetalles_Click"       Style="{StaticResource BtnGhost}"/>
                <Button Content="🗑️ Eliminar"         Click="EliminarReserva_Click"   Style="{StaticResource BtnDanger}"/>
            </StackPanel>
        </Border>

        <!-- ── DataGrid ── -->
        <Border Grid.Row="8"
                Background="{StaticResource BgSurface}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1">
            <DataGrid x:Name="dgReservas"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="None"
                      Margin="0">
                <!-- ComboBox de Estado inline -->
                <DataGrid.Resources>
                    <Style x:Key="EstadoComboBoxRes" TargetType="ComboBox">
                        <Setter Property="Background"      Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"         Value="6,3"/>
                        <Setter Property="FontWeight"      Value="SemiBold"/>
                        <Setter Property="FontSize"        Value="11"/>
                        <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                <Setter Property="Background" Value="{StaticResource RowPending}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="Confirmada">
                                <Setter Property="Background" Value="{StaticResource RowDone}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="En Curso">
                                <Setter Property="Background" Value="{StaticResource RowInProgress}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="Cancelada">
                                <Setter Property="Background" Value="{StaticResource RowCancelled}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="No Asistió">
                                <Setter Property="Background" Value="{StaticResource RowCancelled}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding ReservaID}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="📅 Fecha y Hora"
                                        Binding="{Binding FechaHoraCita, StringFormat='dd/MM/yyyy HH:mm'}"
                                        Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="👤 Cliente"
                                        Binding="{Binding Vehiculo.Cliente.Nombre}" Width="160"/>
                    <DataGridTextColumn Header="📞 Teléfono"
                                        Binding="{Binding Vehiculo.Cliente.Telefono}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="🚗 Vehículo (Placa)" Width="170">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0} ({1})">
                                <Binding Path="Vehiculo.Marca"/>
                                <Binding Path="Vehiculo.Placa"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="🛠️ Servicio"
                                        Binding="{Binding TipoServicio}" Width="130"/>

                    <!-- Estado con ComboBox -->
                    <DataGridTemplateColumn Header="Estado" Width="145">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox SelectedValue="{Binding Estado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource EstadoComboBoxRes}"
                                          SelectionChanged="EstadoComboBox_SelectionChanged">
                                    <ComboBoxItem Content="⏳ Pendiente"   Tag="Pendiente"/>
                                    <ComboBoxItem Content="✅ Confirmada"   Tag="Confirmada"/>
                                    <ComboBoxItem Content="🔄 En Curso"    Tag="En Curso"/>
                                    <ComboBoxItem Content="✓ Completada"   Tag="Completada"/>
                                    <ComboBoxItem Content="❌ Cancelada"    Tag="Cancelada"/>
                                    <ComboBoxItem Content="🚫 No Asistió"  Tag="No Asistió"/>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="⭐ Prioridad"
                                        Binding="{Binding Prioridad}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Prioridad}" Value="Urgente">
                                        <Setter Property="Foreground" Value="{StaticResource ColorDanger}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Prioridad}" Value="VIP">
                                        <Setter Property="Foreground" Value="{StaticResource ColorWarning}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Prioridad}" Value="Normal">
                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
