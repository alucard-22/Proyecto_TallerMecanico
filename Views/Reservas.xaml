<Page x:Class="Proyecto_taller.Views.Reservas"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Módulo de Reservas"
      Background="{StaticResource BgPrimary}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6366F1" Offset="0"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="📅" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Gestión de Reservas" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="Administra citas y reservas de clientes"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Badge total -->
                <Border Grid.Column="1"
                        Background="{StaticResource AccentMuted}"
                        CornerRadius="8" Padding="14,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total: "
                                   Foreground="{StaticResource AccentLight}"
                                   FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock x:Name="txtTotalReservas"
                                   Text="0"
                                   Foreground="{StaticResource AccentLight}"
                                   FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Estadísticas rápidas ── -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📅  Hoy" Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="statHoy" Text="0"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource AccentLight}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="⏳  Pendientes" Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="statPendientes" Text="0"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource ColorWarning}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="✅  Confirmadas" Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="statConfirmadas" Text="0"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource ColorSuccess}"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="🔄  En Curso" Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="statEnCurso" Text="0"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource ColorInfo}"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="📊  Este Mes" Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock x:Name="statMes" Text="0"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Filtros y búsqueda ── -->
        <Border Grid.Row="4" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Filtros de estado -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Estado:"
                               Foreground="{StaticResource TextSecondary}"
                               FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <RadioButton x:Name="rbTodas"      Content="📋  Todas"
                                 GroupName="FiltroEst" IsChecked="True"
                                 Checked="Filtro_Changed" VerticalAlignment="Center"/>
                    <RadioButton x:Name="rbPendientes" Content="⏳  Pendientes"
                                 GroupName="FiltroEst"
                                 Checked="Filtro_Changed" VerticalAlignment="Center"/>
                    <RadioButton x:Name="rbConfirmadas" Content="✅  Confirmadas"
                                 GroupName="FiltroEst"
                                 Checked="Filtro_Changed" VerticalAlignment="Center"/>
                    <RadioButton x:Name="rbEnCurso"    Content="🔄  En Curso"
                                 GroupName="FiltroEst"
                                 Checked="Filtro_Changed" VerticalAlignment="Center"/>
                    <RadioButton x:Name="rbCompletadas" Content="✓  Completadas"
                                 GroupName="FiltroEst"
                                 Checked="Filtro_Changed" VerticalAlignment="Center"/>
                    <RadioButton x:Name="rbCanceladas" Content="❌  Canceladas"
                                 GroupName="FiltroEst"
                                 Checked="Filtro_Changed" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Búsqueda -->
                <Border Grid.Column="2"
                        Background="{StaticResource BgInput}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍"
                                   FontSize="12" VerticalAlignment="Center"
                                   Margin="10,0,5,0" Opacity="0.5"
                                   Foreground="{StaticResource TextSecondary}"/>
                        <TextBox Grid.Column="1" x:Name="txtBuscar"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="4,9"
                                 TextChanged="TxtBuscar_Changed"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ── Barra de acciones ── -->
        <Border Grid.Row="6" Style="{StaticResource Card}" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <!-- Grupo izquierdo: CRUD -->
                <Button Content="🔄  Actualizar"
                        Click="Actualizar_Click"
                        Style="{StaticResource BtnSecondary}"/>
                <Button Content="➕  Nueva Reserva"
                        Click="NuevaReserva_Click"
                        Style="{StaticResource BtnPrimary}"/>

                <Border Width="1" Background="{StaticResource BorderColor}"
                        Margin="8,4" Opacity="0.5"/>

                <!-- Grupo centro: transiciones de estado -->
                <Button Content="✅  Confirmar"
                        Click="Confirmar_Click"
                        Style="{StaticResource BtnSuccess}"
                        ToolTip="Confirmar reserva pendiente + enviar WhatsApp"/>
                <Button Content="🚀  Iniciar"
                        Click="Iniciar_Click"
                        Style="{StaticResource BtnWarning}"
                        ToolTip="Marcar como En Curso"/>
                <Button Content="✓  Completar"
                        Click="Completar_Click"
                        Style="{StaticResource BtnSuccess}"
                        ToolTip="Marcar como Completada"/>
                <Button Content="❌  Cancelar"
                        Click="Cancelar_Click"
                        Style="{StaticResource BtnDanger}"
                        ToolTip="Cancelar y notificar al cliente por WhatsApp"/>

                <Border Width="1" Background="{StaticResource BorderColor}"
                        Margin="8,4" Opacity="0.5"/>

                <!-- Grupo derecho: utilidades -->
                <Button Content="📋  Detalles"
                        Click="Detalles_Click"
                        Style="{StaticResource BtnGhost}"/>
                <Button Content="💬  WhatsApp"
                        Click="WhatsApp_Click"
                        Style="{StaticResource BtnGhost}"
                        ToolTip="Enviar mensaje WhatsApp manualmente a la reserva seleccionada"/>
                <Button Content="🗑️  Eliminar"
                        Click="Eliminar_Click"
                        Style="{StaticResource BtnDanger}"/>
            </StackPanel>
        </Border>

        <!-- ── DataGrid ── -->
        <Border Grid.Row="8"
                Background="{StaticResource BgSurface}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1">
            <DataGrid x:Name="dgReservas"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="None"
                      MouseDoubleClick="dgReservas_DoubleClick"
                      Margin="0">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                <Setter Property="Background" Value="{StaticResource RowPending}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="Confirmada">
                                <Setter Property="Background" Value="{StaticResource RowDone}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="En Curso">
                                <Setter Property="Background" Value="{StaticResource RowInProgress}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="Cancelada">
                                <Setter Property="Background" Value="{StaticResource RowCancelled}"/>
                                <Setter Property="Opacity"    Value="0.65"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="No Asistió">
                                <Setter Property="Background" Value="{StaticResource RowCancelled}"/>
                                <Setter Property="Opacity"    Value="0.55"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding ReservaID}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Estado con badge de color (sin ComboBox inline — evita bugs) -->
                    <DataGridTemplateColumn Header="Estado" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="badge" CornerRadius="12"
                                        Padding="10,3" Margin="6,0" HorizontalAlignment="Left">
                                    <TextBlock x:Name="txtEstado"
                                               Text="{Binding Estado}"
                                               FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                        <Setter TargetName="badge"    Property="Background" Value="#3D2E18"/>
                                        <Setter TargetName="txtEstado" Property="Foreground" Value="#F59E0B"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Estado}" Value="Confirmada">
                                        <Setter TargetName="badge"    Property="Background" Value="#182820"/>
                                        <Setter TargetName="txtEstado" Property="Foreground" Value="#10B981"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Estado}" Value="En Curso">
                                        <Setter TargetName="badge"    Property="Background" Value="#1A2535"/>
                                        <Setter TargetName="txtEstado" Property="Foreground" Value="#3B82F6"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Estado}" Value="Completada">
                                        <Setter TargetName="badge"    Property="Background" Value="#312E6B"/>
                                        <Setter TargetName="txtEstado" Property="Foreground" Value="#818CF8"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Estado}" Value="Cancelada">
                                        <Setter TargetName="badge"    Property="Background" Value="#2D1A1A"/>
                                        <Setter TargetName="txtEstado" Property="Foreground" Value="#EF4444"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Estado}" Value="No Asistió">
                                        <Setter TargetName="badge"    Property="Background" Value="#2D1A1A"/>
                                        <Setter TargetName="txtEstado" Property="Foreground" Value="#EF4444"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="📅 Fecha y Hora"
                                        Binding="{Binding FechaHoraCita, StringFormat='dd/MM/yyyy  HH:mm'}"
                                        Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="👤 Cliente" Width="160">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0} {1}">
                                <Binding Path="Vehiculo.Cliente.Nombre"/>
                                <Binding Path="Vehiculo.Cliente.Apellido"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="📞 Teléfono"
                                        Binding="{Binding Vehiculo.Cliente.Telefono}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="🚗 Vehículo (Placa)" Width="170">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0} {1}  ({2})">
                                <Binding Path="Vehiculo.Marca"/>
                                <Binding Path="Vehiculo.Modelo"/>
                                <Binding Path="Vehiculo.Placa"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="12"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="🔧 Servicio"
                                        Binding="{Binding TipoServicio}" Width="140"/>

                    <!-- Prioridad con color -->
                    <DataGridTemplateColumn Header="⭐ Prioridad" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock x:Name="txtPrioridad"
                                           Text="{Binding Prioridad}"
                                           FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Prioridad}" Value="Urgente">
                                        <Setter TargetName="txtPrioridad" Property="Foreground" Value="{StaticResource ColorDanger}"/>
                                        <Setter TargetName="txtPrioridad" Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Prioridad}" Value="VIP">
                                        <Setter TargetName="txtPrioridad" Property="Foreground" Value="{StaticResource ColorWarning}"/>
                                        <Setter TargetName="txtPrioridad" Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
