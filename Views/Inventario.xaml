<Page x:Class="Proyecto_taller.Views.Inventario"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Módulo de Inventario"
      Background="{StaticResource BgPrimary}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header / Toolbar ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título + badges -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="8" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="📦" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Gestión de Inventario" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Control de repuestos y stock"
                                       Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Border Background="#3D1A1A" CornerRadius="20" Padding="14,6" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️ Stock Bajo: " Foreground="#FCA5A5"
                                           FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{Binding RepuestosStockBajo}"
                                           Foreground="#FCA5A5" FontWeight="Bold" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#182820" CornerRadius="20" Padding="14,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Total: " Foreground="#6EE7B7"
                                           FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{Binding TotalRepuestos}"
                                           Foreground="#6EE7B7" FontWeight="Bold" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Botones -->
                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button Content="🔄 Actualizar"       Command="{Binding CargarRepuestosCommand}" Style="{StaticResource BtnSecondary}"/>
                    <Button Content="➕ Agregar Repuesto"  Command="{Binding AgregarRepuestoCommand}" Style="{StaticResource BtnPrimary}"/>
                    <Button Content="✏️ Editar"            Command="{Binding EditarRepuestoCommand}"  Style="{StaticResource BtnGhost}"/>
                    <Button Content="📥 Entrada Stock"     Command="{Binding EntradaStockCommand}"    Style="{StaticResource BtnSuccess}"/>
                    <Button Content="📤 Salida Stock"      Command="{Binding SalidaStockCommand}"     Style="{StaticResource BtnWarning}"/>
                    <Button Content="🗑️ Eliminar"          Command="{Binding EliminarRepuestoCommand}" Style="{StaticResource BtnDanger}"/>
                </StackPanel>

                <!-- Filtros -->
                <StackPanel Grid.Row="4" Orientation="Horizontal">
                    <TextBlock Text="Filtrar:"
                               Foreground="{StaticResource TextSecondary}"
                               FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <RadioButton Content="Todos"      IsChecked="{Binding FiltroTodos}"     GroupName="FiltroInv" VerticalAlignment="Center"/>
                    <RadioButton Content="Stock Bajo" IsChecked="{Binding FiltroStockBajo}" GroupName="FiltroInv" VerticalAlignment="Center"/>
                    <RadioButton Content="Sin Stock"  IsChecked="{Binding FiltroSinStock}"  GroupName="FiltroInv" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── DataGrid ── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurface}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1">
            <DataGrid ItemsSource="{Binding Repuestos}"
                      SelectedItem="{Binding RepuestoSeleccionado}"
                      Margin="0">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EsStockBajo}" Value="True">
                                <Setter Property="Background" Value="#2D2010"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StockActual}" Value="0">
                                <Setter Property="Background" Value="{StaticResource RowCancelled}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding RepuestoID}" Width="65" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Nombre"       Binding="{Binding Nombre}"       Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Descripción"  Binding="{Binding Descripcion}"  Width="*"/>
                    <DataGridTextColumn Header="Precio Unit."
                                        Binding="{Binding PrecioUnitario, StringFormat=Bs. {0:N2}}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Stock Actual" Binding="{Binding StockActual}"  Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Stock Mínimo" Binding="{Binding StockMinimo}"  Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Valor Total"
                                        Binding="{Binding ValorTotal, StringFormat=Bs. {0:N2}}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Fecha Registro"
                                        Binding="{Binding FechaRegistro, StringFormat=dd/MM/yyyy}"
                                        Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                <Setter Property="FontSize" Value="11"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
