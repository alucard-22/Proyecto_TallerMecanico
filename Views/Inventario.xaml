<Page x:Class="Proyecto_taller.Views.Inventario"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:Proyecto_taller.Helpers"
      Title="Módulo de Inventario"
      Background="{StaticResource BgPrimary}">

    <Page.Resources>
        <helpers:StringToVisibilityConverter x:Key="StrToVis"/>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header / Toolbar ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título + badges de estadísticas -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="8" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="📦" FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Gestión de Inventario"
                                       Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Control de repuestos, stock y movimientos"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Badges de resumen -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Border Background="#3D1A1A" CornerRadius="8"
                                Padding="12,6" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️ Stock bajo: "
                                           Foreground="#FCA5A5"
                                           FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{Binding RepuestosStockBajo}"
                                           Foreground="#FCA5A5"
                                           FontWeight="Bold" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#182820" CornerRadius="8"
                                Padding="12,6" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Total: "
                                           Foreground="#6EE7B7"
                                           FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{Binding TotalRepuestos}"
                                           Foreground="#6EE7B7"
                                           FontWeight="Bold" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource AccentMuted}"
                                CornerRadius="8" Padding="12,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Valor inv.: "
                                           Foreground="{StaticResource AccentLight}"
                                           FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{Binding ValorTotalInventario, StringFormat=Bs. {0:N2}}"
                                           Foreground="{StaticResource AccentLight}"
                                           FontWeight="Bold" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Barra de búsqueda -->
                <Border Grid.Row="2"
                        Background="{StaticResource BgInput}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="12,0,6,0" Opacity="0.5"
                                   Foreground="{StaticResource TextSecondary}"/>
                        <TextBox Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="4,10"
                                 Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2"
                                Content="✕"
                                Command="{Binding LimpiarBusquedaCommand}"
                                Background="Transparent"
                                Foreground="{StaticResource TextMuted}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="10,0"
                                FontSize="13"
                                Visibility="{Binding TextoBusqueda,
                                             Converter={StaticResource StrToVis}}"/>
                    </Grid>
                </Border>

                <!-- Botones de acción -->
                <StackPanel Grid.Row="4" Orientation="Horizontal">
                    <Button Content="🔄  Actualizar"
                            Command="{Binding CargarRepuestosCommand}"
                            Style="{StaticResource BtnSecondary}"/>
                    <Button Content="➕  Nuevo Repuesto"
                            Command="{Binding AgregarRepuestoCommand}"
                            Style="{StaticResource BtnPrimary}"/>
                    <Button Content="✏️  Editar"
                            Command="{Binding EditarRepuestoCommand}"
                            Style="{StaticResource BtnGhost}"/>

                    <Border Width="1" Background="{StaticResource BorderColor}"
                            Margin="8,4" Opacity="0.5"/>

                    <Button Content="📥  Entrada Stock"
                            Command="{Binding EntradaStockCommand}"
                            Style="{StaticResource BtnSuccess}"
                            ToolTip="Registrar entrada de mercadería"/>
                    <Button Content="📤  Salida Stock"
                            Command="{Binding SalidaStockCommand}"
                            Style="{StaticResource BtnWarning}"
                            ToolTip="Registrar salida o ajuste de inventario"/>

                    <Border Width="1" Background="{StaticResource BorderColor}"
                            Margin="8,4" Opacity="0.5"/>

                    <Button Content="🗑️  Eliminar"
                            Command="{Binding EliminarRepuestoCommand}"
                            Style="{StaticResource BtnDanger}"/>
                </StackPanel>

                <!-- Filtros -->
                <StackPanel Grid.Row="6" Orientation="Horizontal">
                    <TextBlock Text="Mostrar:"
                               Foreground="{StaticResource TextSecondary}"
                               FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <RadioButton Content="Todos"
                                 IsChecked="{Binding FiltroTodos}"
                                 GroupName="FiltroInv"
                                 VerticalAlignment="Center"/>
                    <RadioButton Content="⚠️  Stock bajo"
                                 IsChecked="{Binding FiltroStockBajo}"
                                 GroupName="FiltroInv"
                                 VerticalAlignment="Center"/>
                    <RadioButton Content="❌  Sin stock"
                                 IsChecked="{Binding FiltroSinStock}"
                                 GroupName="FiltroInv"
                                 VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── DataGrid ── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurface}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1">
            <DataGrid ItemsSource="{Binding Repuestos}"
                      SelectedItem="{Binding RepuestoSeleccionado}"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      Margin="0">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow"
                           BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StockActual}" Value="0">
                                <Setter Property="Background"
                                        Value="{StaticResource RowCancelled}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding EsStockBajo}" Value="True">
                                <Setter Property="Background" Value="#2D2010"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding RepuestoID}"
                                        Width="65" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource AccentLight}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Nombre"
                                        Binding="{Binding Nombre}"
                                        Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Descripción"
                                        Binding="{Binding Descripcion}"
                                        Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{StaticResource TextSecondary}"/>
                                <Setter Property="TextTrimming"
                                        Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Precio unit."
                                        Binding="{Binding PrecioUnitario, StringFormat=Bs. {0:N2}}"
                                        Width="115"/>

                    <!-- Stock actual con indicador de punto de color -->
                    <DataGridTemplateColumn Header="Stock actual" Width="115">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="14,0">
                                    <Border Width="8" Height="8"
                                            CornerRadius="4"
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background"
                                                        Value="{StaticResource ColorSuccess}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EsStockBajo}"
                                                                 Value="True">
                                                        <Setter Property="Background"
                                                                Value="{StaticResource ColorWarning}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StockActual}"
                                                                 Value="0">
                                                        <Setter Property="Background"
                                                                Value="{StaticResource ColorDanger}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding StockActual}"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource ColorSuccess}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EsStockBajo}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource ColorWarning}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StockActual}"
                                                                 Value="0">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource ColorDanger}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Stock mín."
                                        Binding="{Binding StockMinimo}"
                                        Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource TextMuted}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Valor total"
                                        Binding="{Binding ValorTotal, StringFormat=Bs. {0:N2}}"
                                        Width="115">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{StaticResource AccentLight}"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,14,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Fecha registro"
                                        Binding="{Binding FechaRegistro, StringFormat=dd/MM/yyyy}"
                                        Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{StaticResource TextMuted}"/>
                                <Setter Property="FontSize" Value="11"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
