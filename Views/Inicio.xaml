<Page x:Class="Proyecto_taller.Views.Inicio"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:Proyecto_taller.Helpers"
      Title="Inicio"
      Background="{StaticResource BgPrimary}">

    <Page.Resources>
        <helpers:CountToVisibilityInverseConverter x:Key="CountToVisibilityInverse"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Dashboard · Taller El Choco"
                           Style="{StaticResource PageTitle}"
                           FontSize="26"/>
                <TextBlock Text="Resumen general del sistema"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- ════════════════════════════════════════════
                 Reservas de mañana + recordatorio rápido
                 (movido arriba: es de lo primero que se ve
                 al ingresar al sistema)
            ════════════════════════════════════════════ -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="📅 Citas de Mañana"
                                   Style="{StaticResource SectionTitle}"
                                   FontSize="15"/>
                        <Border Background="{StaticResource AccentMuted}"
                                CornerRadius="10" Padding="10,3"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                            <TextBlock Text="{Binding ReservasManana.Count}"
                                       Foreground="{StaticResource AccentLight}"
                                       FontWeight="Bold" FontSize="11"/>
                        </Border>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding ReservasManana}"
                                  MaxHeight="220">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgCard}"
                                        CornerRadius="6" Padding="10,8"
                                        Margin="0,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding FechaHoraCita, StringFormat='HH:mm'}"
                                                           Foreground="{StaticResource AccentLight}"
                                                           FontWeight="Bold" FontSize="13"
                                                           FontFamily="Consolas"/>
                                                <TextBlock Text="  ·  " Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                                <TextBlock Foreground="{StaticResource TextPrimary}"
                                                           FontSize="12" FontWeight="SemiBold">
                                                    <Run Text="{Binding Vehiculo.Cliente.Nombre}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Vehiculo.Cliente.Apellido}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Text="{Binding TipoServicio}"
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="💬 Recordar"
                                                Command="{Binding DataContext.EnviarRecordatorioCommand,
                                                          RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource BtnGhost}"
                                                Padding="10,5" FontSize="11"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No hay citas pendientes para mañana."
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12" Margin="4,8,0,0"
                               Visibility="{Binding ReservasManana.Count,
                                            Converter={StaticResource CountToVisibilityInverse}}"/>
                </StackPanel>
            </Border>

            <!-- Cards de estadísticas -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Trabajos activos -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="34" Height="34" CornerRadius="8"
                                    Background="{StaticResource AccentMuted}" Margin="0,0,10,0">
                                <TextBlock Text="🛠️" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Trabajos Activos"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TrabajosActivos}"
                                   Foreground="{StaticResource AccentLight}"
                                   FontSize="38" FontWeight="Bold"/>
                        <TextBlock Text="En progreso + Pendientes"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Clientes -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="5,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="34" Height="34" CornerRadius="8"
                                    Background="#1A2535" Margin="0,0,10,0">
                                <TextBlock Text="👥" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Clientes"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalClientes}"
                                   Foreground="{StaticResource ColorInfo}"
                                   FontSize="38" FontWeight="Bold"/>
                        <TextBlock Text="Registrados en el sistema"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Vehículos -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="5,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="34" Height="34" CornerRadius="8"
                                    Background="#1A2535" Margin="0,0,10,0">
                                <TextBlock Text="🚗" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Vehículos"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalVehiculos}"
                                   Foreground="{StaticResource ColorInfo}"
                                   FontSize="38" FontWeight="Bold"/>
                        <TextBlock Text="En el sistema"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Ventas del mes -->
                <Border Grid.Column="3" Style="{StaticResource Card}" Margin="10,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="34" Height="34" CornerRadius="8"
                                    Background="#182820" Margin="0,0,10,0">
                                <TextBlock Text="💰" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Ventas del Mes"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding VentasMes, StringFormat=Bs. {0:N0}}"
                                   Foreground="#6EE7B7"
                                   FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="Facturado este mes"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Contenido inferior -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- Registro rápido -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="⚡ Registro de Trabajo"
                                   Foreground="{StaticResource AccentLight}"
                                   FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Registra un nuevo trabajo de manera rápida y sencilla."
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="13" TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>
                        <Button Content="📝  Registrar Nuevo Trabajo"
                                Command="{Binding AbrirRegistroRapidoCommand}"
                                Style="{StaticResource BtnPrimary}"
                                Padding="24,14" FontSize="14" Margin="0"/>
                    </StackPanel>
                </Border>

                <!-- Actividad + Pendientes + Stock Bajo + Citas de mañana -->
                <StackPanel Grid.Column="2">
                    <!-- Actividad reciente -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="📊 Actividad Reciente"
                                       Style="{StaticResource SectionTitle}"
                                       FontSize="15"/>
                            <ListBox ItemsSource="{Binding ActividadReciente}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     MaxHeight="180">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Margin="0,4" TextWrapping="Wrap" FontSize="12"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- Trabajos pendientes -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="⏰ Trabajos Pendientes"
                                       Style="{StaticResource SectionTitle}"
                                       FontSize="15"/>
                            <DataGrid ItemsSource="{Binding TrabajosPendientes}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      MaxHeight="180">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"       Binding="{Binding TrabajoID}"               Width="50"/>
                                    <DataGridTextColumn Header="Vehículo" Binding="{Binding Vehiculo.Marca}"           Width="*"/>
                                    <DataGridTextColumn Header="Cliente"  Binding="{Binding Vehiculo.Cliente.Nombre}" Width="*"/>
                                    <DataGridTextColumn Header="Estado"   Binding="{Binding Estado}"                  Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Stock bajo -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="⚠️ Repuestos con Stock Bajo"
                                       Style="{StaticResource SectionTitle}"
                                       FontSize="15"/>
                            <ListBox ItemsSource="{Binding RepuestosStockBajo}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     MaxHeight="140">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,4">
                                            <TextBlock Text="•" Foreground="{StaticResource ColorDanger}"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Nombre}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       Width="200" FontSize="12"/>
                                            <TextBlock Text="Stock: "
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontSize="12"/>
                                            <TextBlock Text="{Binding StockActual}"
                                                       Foreground="{StaticResource ColorDanger}"
                                                       FontWeight="Bold" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
