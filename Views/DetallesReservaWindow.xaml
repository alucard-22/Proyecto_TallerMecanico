<Window x:Class="Proyecto_taller.Views.DetallesReservaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalles de la Reserva"
        Height="750" Width="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimary}">

    <Window.Resources>
        <!-- Etiqueta de campo (ej: "Nombre:") -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin"      Value="0,0,0,3"/>
        </Style>

        <!-- Valor de campo (ej: "Juan Pérez") -->
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="Foreground"    Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin"        Value="0,0,0,14"/>
            <Setter Property="TextWrapping"  Value="Wrap"/>
        </Style>

        <!-- Tarjeta de sección -->
        <Style x:Key="DetailCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BgSurface}"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="20"/>
            <Setter Property="Margin"          Value="0,0,0,12"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0"
                Background="{StaticResource AccentPrimary}"
                Padding="24,20">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="txtTitulo"
                               Text="Reserva #"
                               Foreground="White"
                               FontSize="22" FontWeight="Bold"/>
                    <Border Background="#FFFFFF22"
                            CornerRadius="12" Padding="10,4"
                            Margin="0,8,0,0" HorizontalAlignment="Left">
                        <TextBlock x:Name="txtEstado"
                                   Text="Pendiente"
                                   FontWeight="SemiBold" FontSize="12"
                                   Foreground="White"/>
                    </Border>
                </StackPanel>

                <Button Content="✕"
                        Click="Cerrar_Click"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="20" FontWeight="Bold"
                        Cursor="Hand" Padding="12,6"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <!-- ── Contenido scrolleable ── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource BgPrimary}"
                      Padding="24,20">
            <StackPanel>

                <!-- Información de la Reserva -->
                <Border Style="{StaticResource DetailCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="📅 Información de la Reserva"
                                       Style="{StaticResource SectionTitle}"
                                       FontSize="14" Margin="0,0,0,14"/>

                            <TextBlock Text="Fecha y Hora de la Cita:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txtFechaHoraCita"
                                       Style="{StaticResource FieldValue}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentLight}"/>

                            <TextBlock Text="Tipo de Servicio:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txtTipoServicio" Style="{StaticResource FieldValue}"/>

                            <TextBlock Text="Prioridad:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txtPrioridad" Style="{StaticResource FieldValue}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text=" " FontSize="14" Margin="0,0,0,14"/>

                            <TextBlock Text="Precio Estimado:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txtPrecioEstimado"
                                       Style="{StaticResource FieldValue}"
                                       FontWeight="SemiBold"
                                       Foreground="#6EE7B7"/>

                            <TextBlock Text="Observaciones:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txtObservaciones"
                                       Style="{StaticResource FieldValue}"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Información del Cliente -->
                <Border Style="{StaticResource DetailCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="👤 Información del Cliente"
                                       Style="{StaticResource SectionTitle}"
                                       FontSize="14" Margin="0,0,0,14"/>

                            <TextBlock Text="Nombre Completo:"  Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txtNombreCliente"
                                       Style="{StaticResource FieldValue}"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="Teléfono:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txtTelefonoCliente"
                                       Style="{StaticResource FieldValue}"
                                       FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text=" " FontSize="14" Margin="0,0,0,14"/>

                            <TextBlock Text="Email:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txtEmailCliente"
                                       Style="{StaticResource FieldValue}"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Información del Vehículo -->
                <Border x:Name="panelVehiculo" Style="{StaticResource DetailCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="🚗 Información del Vehículo"
                                       Style="{StaticResource SectionTitle}"
                                       FontSize="14" Margin="0,0,0,14"/>

                            <TextBlock Text="Marca y Modelo:" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txtMarcaModelo"
                                       Style="{StaticResource FieldValue}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text=" " FontSize="14" Margin="0,0,0,14"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Placa:" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock x:Name="txtPlaca"
                                               Style="{StaticResource FieldValue}"
                                               FontFamily="Consolas"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentLight}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Año:" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock x:Name="txtAnio"
                                               Style="{StaticResource FieldValue}"
                                               Foreground="{StaticResource TextSecondary}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Historial de Fechas -->
                <Border Style="{StaticResource DetailCard}">
                    <StackPanel>
                        <TextBlock Text="📋 Historial"
                                   Style="{StaticResource SectionTitle}"
                                   FontSize="14" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fecha de Creación:"      Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtFechaCreacion"      Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Fecha de Confirmación:"  Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtFechaConfirmacion"  Style="{StaticResource FieldValue}"
                                           Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Fecha de Completado:"    Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtFechaCompletado"    Style="{StaticResource FieldValue}"
                                           Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Panel de Cancelación (condicional) -->
                <Border x:Name="panelCancelacion"
                        Background="#2D1A1A"
                        BorderBrush="{StaticResource ColorDanger}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="20"
                        Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="❌ Información de Cancelación"
                                   Foreground="{StaticResource ColorDanger}"
                                   FontSize="14" FontWeight="Bold"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="Motivo:"              Style="{StaticResource FieldLabel}"
                                   Foreground="#FCA5A5"/>
                        <TextBlock x:Name="txtMotivoCancelacion"
                                   Style="{StaticResource FieldValue}"
                                   Foreground="#FCA5A5"/>

                        <TextBlock Text="Fecha de Cancelación:" Style="{StaticResource FieldLabel}"
                                   Foreground="#FCA5A5"/>
                        <TextBlock x:Name="txtFechaCancelacion"
                                   Style="{StaticResource FieldValue}"
                                   Foreground="#FCA5A5"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Footer ── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <Button Content="✕  Cerrar"
                    Click="Cerrar_Click"
                    HorizontalAlignment="Right"
                    Style="{StaticResource BtnSecondary}"
                    Width="110" Height="38"/>
        </Border>
    </Grid>
</Window>
