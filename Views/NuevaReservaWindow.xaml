<Window x:Class="Proyecto_taller.Views.NuevaReservaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva Reserva"
        Height="780" Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="6" BlurRadius="28" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0" Background="{StaticResource BgCard}"
                    CornerRadius="11,11,0,0" Padding="22,16">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="📅  Nueva Reserva"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Ingresa los datos del cliente y la cita"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="Cancelar_Click"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" FontSize="18" Cursor="Hand"
                            Padding="10,4" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- ── Formulario ── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,18">
                <StackPanel>

                    <!-- DATOS DEL CLIENTE -->
                    <TextBlock Text="👤 DATOS DEL CLIENTE"
                               Style="{StaticResource SectionTitle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nombre: *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtNombre"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Apellido: *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtApellido"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Teléfono: *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtTelefono"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Email:" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtEmail"/>
                        </StackPanel>
                    </Grid>

                    <!-- Separador -->
                    <Border Height="1" Background="{StaticResource BorderColor}"
                            Margin="0,14" Opacity="0.4"/>

                    <!-- DATOS DEL VEHÍCULO -->
                    <TextBlock Text="🚗 DATOS DEL VEHÍCULO"
                               Style="{StaticResource SectionTitle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Marca: *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtMarca"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Modelo: *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtModelo"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Placa: *" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtPlaca"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Año:" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtAnio"/>
                        </StackPanel>
                    </Grid>

                    <!-- Separador -->
                    <Border Height="1" Background="{StaticResource BorderColor}"
                            Margin="0,14" Opacity="0.4"/>

                    <!-- DATOS DE LA CITA -->
                    <TextBlock Text="📅 DATOS DE LA CITA"
                               Style="{StaticResource SectionTitle}"/>

                    <!-- Fecha y Hora -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Fecha de la Cita: *" Style="{StaticResource FormLabel}"/>
                            <DatePicker x:Name="dpFecha"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Hora: *" Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="cmbHora">
                                <ComboBoxItem Content="08:00"/>
                                <ComboBoxItem Content="09:00"/>
                                <ComboBoxItem Content="10:00"/>
                                <ComboBoxItem Content="11:00"/>
                                <ComboBoxItem Content="12:00"/>
                                <ComboBoxItem Content="14:00"/>
                                <ComboBoxItem Content="15:00"/>
                                <ComboBoxItem Content="16:00"/>
                                <ComboBoxItem Content="17:00"/>
                                <ComboBoxItem Content="18:00"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Tipo de Servicio y Prioridad -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tipo de Servicio: *" Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="cmbTipoServicio">
                                <ComboBoxItem Content="Mecánica"               IsSelected="True"/>
                                <ComboBoxItem Content="Electricidad"/>
                                <ComboBoxItem Content="Pintura"/>
                                <ComboBoxItem Content="Laminado"/>
                                <ComboBoxItem Content="Cambio de Aceite"/>
                                <ComboBoxItem Content="Alineación y Balanceo"/>
                                <ComboBoxItem Content="Mantenimiento Preventivo"/>
                                <ComboBoxItem Content="Diagnóstico"/>
                                <ComboBoxItem Content="Otro"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Prioridad:" Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="cmbPrioridad">
                                <ComboBoxItem Content="⚪ Normal"  Tag="Normal"  IsSelected="True"/>
                                <ComboBoxItem Content="🔴 Urgente" Tag="Urgente"/>
                                <ComboBoxItem Content="⭐ VIP"     Tag="VIP"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Precio estimado -->
                    <TextBlock Text="Precio Estimado (Bs.) — Opcional:"
                               Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtPrecioEstimado" Margin="0,0,0,14"/>

                    <!-- Observaciones -->
                    <TextBlock Text="Observaciones:" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtObservaciones"
                             Height="68" TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,16"/>

                    <!-- Nota informativa -->
                    <Border Background="{StaticResource AccentMuted}"
                            CornerRadius="6" Padding="12,10">
                        <TextBlock Foreground="{StaticResource AccentLight}"
                                   FontSize="11" TextWrapping="Wrap">
                            <Run Text="ℹ️  "/>
                            <Run Text="Si el cliente o vehículo ya existe en el sistema (mismo teléfono o placa) se reutilizará automáticamente. Los campos con (*) son obligatorios."/>
                        </TextBlock>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Footer ── -->
            <Border Grid.Row="2" Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11" Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✕  Cancelar" Click="Cancelar_Click"
                            Style="{StaticResource BtnDanger}"/>
                    <Button Content="✅  Guardar Reserva" Click="Guardar_Click"
                            Style="{StaticResource BtnSuccess}" Padding="22,9"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
