<Window x:Class="Proyecto_taller.Views.NuevaReservaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva Reserva"
        Height="700" Width="700"
        MinHeight="520" MinWidth="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource BgSurface}">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1" CornerRadius="0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0" Background="{StaticResource BgCard}"
                    CornerRadius="0" Padding="24,16">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="📅  Nueva Reserva"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Busca un cliente existente o registra uno nuevo"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="Cancelar_Click"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" FontSize="18" Cursor="Hand"
                            Padding="10,4" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- ── Formulario ── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
                <StackPanel>

                    <!-- ══════════════════════════════════════════
                         BLOQUE 1 — Buscar cliente existente
                    ══════════════════════════════════════════ -->
                    <Border Background="{StaticResource BgCard}"
                            CornerRadius="8" Padding="16,14"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="24" Height="24" CornerRadius="5"
                                        Background="{StaticResource AccentMuted}" Margin="0,0,8,0">
                                    <TextBlock Text="🔍" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="BUSCAR CLIENTE EXISTENTE"
                                           Foreground="{StaticResource AccentLight}"
                                           FontSize="11" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Barra de búsqueda -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="{StaticResource BgInput}"
                                        BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="1" CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="🔍"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   Margin="10,0,6,0" Opacity="0.6"/>
                                        <TextBox Grid.Column="1"
                                                 x:Name="txtBuscarCliente"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="4,9"
                                                 TextChanged="TxtBuscarCliente_TextChanged"/>
                                    </Grid>
                                </Border>
                                <Button Grid.Column="2"
                                        Content="🔍 Buscar"
                                        Click="BuscarCliente_Click"
                                        Style="{StaticResource BtnGhost}"
                                        Padding="14,9"/>
                            </Grid>

                            <!-- Resultados de búsqueda -->
                            <Border x:Name="panelResultadosBusqueda"
                                    Visibility="Collapsed"
                                    Background="{StaticResource BgInput}"
                                    BorderBrush="{StaticResource AccentPrimary}"
                                    BorderThickness="1" CornerRadius="6"
                                    Margin="0,6,0,0" MaxHeight="160">
                                <ListBox x:Name="lstResultadosBusqueda"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         SelectionChanged="LstResultados_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4,4">
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="13">
                                                    <Run Text="{Binding Nombre}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Apellido}"/>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📞 "
                                                               Foreground="{StaticResource TextMuted}"
                                                               FontSize="11"/>
                                                    <TextBlock Text="{Binding Telefono}"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontFamily="Consolas" FontSize="11"/>
                                                    <TextBlock Text="  ·  "
                                                               Foreground="{StaticResource TextMuted}"
                                                               FontSize="11"/>
                                                    <TextBlock Text="{Binding Vehiculos.Count, StringFormat={}{0} vehículo(s)}"
                                                               Foreground="{StaticResource TextMuted}"
                                                               FontSize="11"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <!-- Cliente seleccionado (badge verde) -->
                            <Border x:Name="panelClienteSeleccionado"
                                    Visibility="Collapsed"
                                    Background="#182820"
                                    BorderBrush="{StaticResource ColorSuccess}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="12,10" Margin="0,6,0,0">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="✅ Cliente seleccionado"
                                                   Foreground="{StaticResource ColorSuccess}"
                                                   FontSize="10" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="txtClienteSeleccionadoNombre"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="14" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock x:Name="txtClienteSeleccionadoTel"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontFamily="Consolas" FontSize="12"/>
                                            <TextBlock Text="  ·  "
                                                       Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                            <TextBlock x:Name="txtClienteSeleccionadoCorreo"
                                                       Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Content="✕ Cambiar"
                                            Click="LimpiarClienteSeleccionado_Click"
                                            Background="Transparent"
                                            Foreground="{StaticResource TextMuted}"
                                            BorderThickness="0" Cursor="Hand"
                                            FontSize="11" HorizontalAlignment="Right"
                                            VerticalAlignment="Top"/>
                                </Grid>
                            </Border>

                            <!-- Selector de vehículo del cliente (aparece cuando hay cliente seleccionado con vehículos) -->
                            <StackPanel x:Name="panelVehiculoExistente" Visibility="Collapsed"
                                        Margin="0,10,0,0">
                                <TextBlock Text="Vehículo del cliente:"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="cmbVehiculosCliente"
                                              Grid.Column="0"
                                              SelectionChanged="CmbVehiculosCliente_SelectionChanged">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <Run Text="{Binding Marca}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Modelo}"/>
                                                    <Run Text=" — "/>
                                                    <Run Text="{Binding Placa}" FontFamily="Consolas"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Button Grid.Column="2"
                                            Content="➕ Nuevo vehículo"
                                            Click="NuevoVehiculo_Click"
                                            Style="{StaticResource BtnGhost}"
                                            Padding="12,8"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Toggle: ¿nuevo cliente? -->
                    <Border Background="{StaticResource BgCard}"
                            CornerRadius="8" Padding="14,10"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chkNuevoCliente"
                                      Content="Es un cliente nuevo — ingresar datos manualmente"
                                      Foreground="{StaticResource TextSecondary}"
                                      FontSize="13"
                                      Checked="ChkNuevoCliente_Changed"
                                      Unchecked="ChkNuevoCliente_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- ══════════════════════════════════════════
                         BLOQUE 2 — Datos del nuevo cliente
                         (visible solo si chkNuevoCliente = true)
                    ══════════════════════════════════════════ -->
                    <Border x:Name="panelNuevoCliente"
                            Visibility="Collapsed"
                            Background="{StaticResource BgCard}"
                            CornerRadius="8" Padding="16,14"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="24" Height="24" CornerRadius="5"
                                        Background="#1A2535" Margin="0,0,8,0">
                                    <TextBlock Text="👤" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="DATOS DEL NUEVO CLIENTE"
                                           Foreground="{StaticResource ColorInfo}"
                                           FontSize="11" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Nombre: *" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtNombre"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Apellido: *" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtApellido"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Teléfono / WhatsApp: *" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtTelefono"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Correo electrónico:" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtEmail"/>
                                </StackPanel>
                            </Grid>

                            <!-- Datos del vehículo del nuevo cliente -->
                            <Border Height="1" Background="{StaticResource BorderColor}"
                                    Margin="0,14" Opacity="0.4"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="24" Height="24" CornerRadius="5"
                                        Background="#1A2535" Margin="0,0,8,0">
                                    <TextBlock Text="🚗" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="DATOS DEL VEHÍCULO"
                                           Foreground="{StaticResource ColorInfo}"
                                           FontSize="11" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Marca: *" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtMarca"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Modelo: *" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtModelo"/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Placa: *" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtPlaca"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Año:" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtAnio"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ══════════════════════════════════════════
                         BLOQUE 3 — Datos de la cita
                    ══════════════════════════════════════════ -->
                    <Border Background="{StaticResource BgCard}"
                            CornerRadius="8" Padding="16,14"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="24" Height="24" CornerRadius="5"
                                        Background="#2D2010" Margin="0,0,8,0">
                                    <TextBlock Text="📅" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="DATOS DE LA CITA"
                                           Foreground="{StaticResource ColorWarning}"
                                           FontSize="11" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Fecha + Hora -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Fecha de la cita: *" Style="{StaticResource FormLabel}"/>
                                    <DatePicker x:Name="dpFecha"
                                                SelectedDateChanged="DpFecha_Changed"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Hora: *" Style="{StaticResource FormLabel}"/>
                                    <ComboBox x:Name="cmbHora" SelectedIndex="1">
                                        <ComboBoxItem Content="07:00"/>
                                        <ComboBoxItem Content="08:00"/>
                                        <ComboBoxItem Content="09:00"/>
                                        <ComboBoxItem Content="10:00"/>
                                        <ComboBoxItem Content="11:00"/>
                                        <ComboBoxItem Content="12:00"/>
                                        <ComboBoxItem Content="14:00"/>
                                        <ComboBoxItem Content="15:00"/>
                                        <ComboBoxItem Content="16:00"/>
                                        <ComboBoxItem Content="17:00"/>
                                        <ComboBoxItem Content="18:00"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Tipo de servicio + Prioridad -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Tipo de servicio: *" Style="{StaticResource FormLabel}"/>
                                    <ComboBox x:Name="cmbTipoServicio">
                                        <ComboBoxItem Content="Mecánica general"   IsSelected="True"/>
                                        <ComboBoxItem Content="Cambio de aceite"/>
                                        <ComboBoxItem Content="Frenos"/>
                                        <ComboBoxItem Content="Electricidad"/>
                                        <ComboBoxItem Content="Pintura"/>
                                        <ComboBoxItem Content="Laminado"/>
                                        <ComboBoxItem Content="Alineación y balanceo"/>
                                        <ComboBoxItem Content="Mantenimiento preventivo"/>
                                        <ComboBoxItem Content="Diagnóstico"/>
                                        <ComboBoxItem Content="Otro"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Nivel de urgencia:" Style="{StaticResource FormLabel}"/>
                                    <ComboBox x:Name="cmbPrioridad" SelectedIndex="0">
                                        <ComboBoxItem Content="⚪  Normal"  Tag="Normal"/>
                                        <ComboBoxItem Content="🔴  Urgente" Tag="Urgente"/>
                                        <ComboBoxItem Content="⭐  VIP"     Tag="VIP"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Precio estimado + Observaciones -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Precio estimado (Bs.):" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtPrecioEstimado"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Observaciones:" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtObservaciones"
                                             Height="56"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ══════════════════════════════════════════
                         BLOQUE 4 — WhatsApp
                    ══════════════════════════════════════════ -->
                    <Border Background="{StaticResource BgCard}"
                            CornerRadius="8" Padding="14,12"
                            BorderBrush="{StaticResource ColorSuccess}"
                            BorderThickness="1" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💬" FontSize="16" Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>
                            <StackPanel>
                                <CheckBox x:Name="chkEnviarWhatsApp"
                                          IsChecked="True"
                                          Foreground="{StaticResource TextPrimary}"
                                          FontSize="13" FontWeight="SemiBold"
                                          Content="Enviar confirmación por WhatsApp al guardar"/>
                                <TextBlock Text="Se abrirá el navegador con el mensaje listo para enviar."
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11" Margin="20,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Footer ── -->
            <Border Grid.Row="2" Background="{StaticResource BgCard}"
                    CornerRadius="0" Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✕  Cancelar"
                            Click="Cancelar_Click"
                            Style="{StaticResource BtnDanger}"/>
                    <Button Content="💾  Guardar Reserva"
                            Click="Guardar_Click"
                            Style="{StaticResource BtnSuccess}"
                            Padding="22,9"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
