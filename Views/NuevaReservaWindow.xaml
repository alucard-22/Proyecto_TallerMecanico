<Window x:Class="Proyecto_taller.Views.NuevaReservaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nueva Reserva" 
        Height="700" 
        Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Border Background="White" CornerRadius="10" Margin="20" Padding="30">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="2" BlurRadius="15" Opacity="0.15"/>
        </Border.Effect>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- HEADER -->
                <TextBlock Text="📅 Nueva Reserva" FontSize="24" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,10"/>
                <TextBlock Text="Complete la información para crear una nueva reserva" FontSize="13" Foreground="#6C757D" Margin="0,0,0,30"/>

                <!-- VEHÍCULO (Cliente + Vehículo) -->
                <TextBlock Text="Vehículo (Cliente - Vehículo) *" FontSize="13" FontWeight="Medium" Foreground="#495057" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbVehiculo" Height="40" FontSize="14" Margin="0,0,0,20"/>

                <!-- FECHA Y HORA -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Fecha de la Cita *" FontSize="13" FontWeight="Medium" Foreground="#495057" Margin="0,0,0,5"/>
                        <DatePicker x:Name="dpFecha" Height="40" FontSize="14"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Hora *" FontSize="13" FontWeight="Medium" Foreground="#495057" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbHora" Height="40" FontSize="14">
                            <ComboBoxItem Content="08:00"/>
                            <ComboBoxItem Content="09:00"/>
                            <ComboBoxItem Content="10:00"/>
                            <ComboBoxItem Content="11:00"/>
                            <ComboBoxItem Content="12:00"/>
                            <ComboBoxItem Content="14:00"/>
                            <ComboBoxItem Content="15:00"/>
                            <ComboBoxItem Content="16:00"/>
                            <ComboBoxItem Content="17:00"/>
                            <ComboBoxItem Content="18:00"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- TIPO DE SERVICIO -->
                <TextBlock Text="Tipo de Servicio *" FontSize="13" FontWeight="Medium" Foreground="#495057" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbTipoServicio" Height="40" FontSize="14" Margin="0,0,0,20">
                    <ComboBoxItem Content="Mecánica" IsSelected="True"/>
                    <ComboBoxItem Content="Electricidad"/>
                    <ComboBoxItem Content="Pintura"/>
                    <ComboBoxItem Content="Laminado"/>
                    <ComboBoxItem Content="Cambio de Aceite"/>
                    <ComboBoxItem Content="Alineación y Balanceo"/>
                    <ComboBoxItem Content="Mantenimiento Preventivo"/>
                    <ComboBoxItem Content="Diagnóstico"/>
                    <ComboBoxItem Content="Otro"/>
                </ComboBox>

                <!-- PRIORIDAD -->
                <TextBlock Text="Prioridad" FontSize="13" FontWeight="Medium" Foreground="#495057" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbPrioridad" Height="40" FontSize="14" Margin="0,0,0,20">
                    <ComboBoxItem Content="⚪ Normal" Tag="Normal" IsSelected="True"/>
                    <ComboBoxItem Content="🔴 Urgente" Tag="Urgente"/>
                    <ComboBoxItem Content="⭐ VIP" Tag="VIP"/>
                </ComboBox>

                <!-- PRECIO ESTIMADO -->
                <TextBlock Text="Precio Estimado (Opcional)" FontSize="13" FontWeight="Medium" Foreground="#495057" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,20">
                    <TextBlock Text="Bs." VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#6C757D" FontSize="14"/>
                    <TextBox x:Name="txtPrecioEstimado" Height="40" FontSize="14" Padding="30,0,10,0"/>
                </Grid>

                <!-- OBSERVACIONES -->
                <TextBlock Text="Observaciones" FontSize="13" FontWeight="Medium" Foreground="#495057" Margin="0,0,0,5"/>
                <TextBox x:Name="txtObservaciones" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="13" Padding="10" Margin="0,0,0,30"/>

                <!-- BOTONES -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="✓ Guardar" Click="Guardar_Click" Height="45" FontSize="14" FontWeight="SemiBold" Background="#28A745" Foreground="White" BorderThickness="0" Margin="0,0,5,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#218838"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Column="1" Content="✕ Cancelar" Click="Cancelar_Click" Height="45" FontSize="14" FontWeight="SemiBold" Background="#6C757D" Foreground="White" BorderThickness="0" Margin="5,0,0,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#5A6268"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
