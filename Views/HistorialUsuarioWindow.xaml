<Window x:Class="Proyecto_taller.Views.HistorialUsuarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Proyecto_taller.Helpers"
        Title="Historial del Usuario"
        Height="500" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270"
                              ShadowDepth="6" BlurRadius="24" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgCard}"
                    CornerRadius="11,11,0,0"
                    Padding="22,16">
                <Grid>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtTitulo"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="17" FontWeight="Bold"/>
                            <Border x:Name="badgeRol"
                                    CornerRadius="10" Padding="10,3"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource AccentMuted}">
                                <TextBlock x:Name="txtRol"
                                           Foreground="{StaticResource AccentLight}"
                                           FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="txtSubtitulo"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="Cerrar_Click"
                            Background="Transparent"
                            Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" FontSize="16"
                            Cursor="Hand" Padding="8,4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- Contenido -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="22,16">
                <StackPanel>

                    <!-- Ficha del usuario -->
                    <Border Background="{StaticResource BgCard}"
                            CornerRadius="8" Padding="16,14"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CUENTA"
                                           Foreground="{StaticResource AccentLight}"
                                           FontSize="10" FontWeight="Bold"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Usuario:"
                                           Style="{StaticResource FormLabel}"/>
                                <TextBlock x:Name="txtNombreUsuario"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontFamily="Consolas"
                                           FontSize="14" FontWeight="Bold"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Nombre completo:"
                                           Style="{StaticResource FormLabel}"/>
                                <TextBlock x:Name="txtNombreCompleto"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="13"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Estado:"
                                           Style="{StaticResource FormLabel}"/>
                                <TextBlock x:Name="txtEstado"
                                           FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="ACTIVIDAD"
                                           Foreground="{StaticResource ColorInfo}"
                                           FontSize="10" FontWeight="Bold"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Fecha de creación:"
                                           Style="{StaticResource FormLabel}"/>
                                <TextBlock x:Name="txtFechaCreacion"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="13"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Último acceso:"
                                           Style="{StaticResource FormLabel}"/>
                                <TextBlock x:Name="txtUltimoAcceso"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="13"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Último cambio de contraseña:"
                                           Style="{StaticResource FormLabel}"/>
                                <TextBlock x:Name="txtUltimoCambioPass"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="13"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Estadísticas de acceso -->
                    <TextBlock Text="📊  Estadísticas del período (últimos 30 días)"
                               Style="{StaticResource SectionTitle}"
                               FontSize="14" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource BgCard}"
                                CornerRadius="8" Padding="14,10"
                                Margin="0,0,6,0"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Días activo"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11"/>
                                <TextBlock x:Name="txtDiasActivo"
                                           Foreground="{StaticResource AccentLight}"
                                           FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{StaticResource BgCard}"
                                CornerRadius="8" Padding="14,10"
                                Margin="3,0"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Cambios de contraseña"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11"/>
                                <TextBlock x:Name="txtCambiosPass"
                                           Foreground="{StaticResource ColorWarning}"
                                           FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource BgCard}"
                                CornerRadius="8" Padding="14,10"
                                Margin="6,0,0,0"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Rol actual"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11"/>
                                <TextBlock x:Name="txtRolCard"
                                           FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Información de seguridad -->
                    <Border Background="{StaticResource AccentMuted}"
                            CornerRadius="6" Padding="12,10">
                        <TextBlock Foreground="{StaticResource AccentLight}"
                                   FontSize="11" TextWrapping="Wrap">
                            <Run Text="ℹ️  "/>
                            <Run Text="El sistema registra la fecha y hora del último acceso y del último cambio de contraseña. Para ver o modificar los datos del usuario usa los botones Editar y Cambiar Contraseña del módulo de Usuarios."/>
                        </TextBlock>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11"
                    Padding="22,14">
                <Button Content="✕  Cerrar"
                        Click="Cerrar_Click"
                        Style="{StaticResource BtnSecondary}"
                        HorizontalAlignment="Right"
                        Width="120"/>
            </Border>
        </Grid>
    </Border>
</Window>
