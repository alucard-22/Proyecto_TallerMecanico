<!-- CONFIGURACION.XAML -->
<Page x:Class="Proyecto_taller.Views.Configuracion"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Configuración"
      Background="{StaticResource BgPrimary}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="⚙️ Configuración del Sistema"
                           Style="{StaticResource PageTitle}" FontSize="26"/>
                <TextBlock Text="Gestiona la información del taller y parámetros del sistema"
                           Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="2">

                <!-- Información del Taller -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🏢 Información del Taller" Style="{StaticResource SectionTitle}" FontSize="16"/>

                        <TextBlock Text="Nombre del Taller:" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding NombreTaller, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="Dirección:" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding DireccionTaller, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Teléfono:" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding TelefonoTaller, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Email:" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding EmailTaller, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="NIT:" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding NITTaller, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                        <Button Content="💾 Guardar Información"
                                Command="{Binding GuardarInformacionCommand}"
                                Style="{StaticResource BtnPrimary}"
                                HorizontalAlignment="Left" Margin="0"/>
                    </StackPanel>
                </Border>

                <!-- Facturación -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="📄 Configuración de Facturación" Style="{StaticResource SectionTitle}" FontSize="16"/>

                        <TextBlock Text="Descuento Máximo (%):" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding DescuentoMaximo, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <CheckBox Content="Solicitar NIT en todas las facturas"
                                  IsChecked="{Binding SolicitarNIT}"
                                  Margin="0,0,0,16"/>

                        <Button Content="💾 Guardar Facturación"
                                Command="{Binding GuardarFacturacionCommand}"
                                Style="{StaticResource BtnPrimary}"
                                HorizontalAlignment="Left" Margin="0"/>
                    </StackPanel>
                </Border>

                <!-- Base de Datos -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🗄️ Base de Datos" Style="{StaticResource SectionTitle}" FontSize="16"/>

                        <TextBlock Text="Cadena de Conexión:" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding ConnectionString}" IsReadOnly="True"
                                 Background="{StaticResource BgCard}" Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="🔄 Probar Conexión"       Command="{Binding ProbarConexionCommand}" Style="{StaticResource BtnGhost}"/>
                            <Button Content="📦 Respaldar Base de Datos" Command="{Binding RespaldarBDCommand}"   Style="{StaticResource BtnPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Servicios -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🔧 Gestión de Servicios" Style="{StaticResource SectionTitle}" FontSize="16"/>
                        <ListBox ItemsSource="{Binding Servicios}"
                                 Height="140"
                                 Background="{StaticResource BgInput}"
                                 BorderBrush="{StaticResource BorderColor}"
                                 BorderThickness="1"
                                 Margin="0,0,0,14">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <TextBlock Text="{Binding Nombre}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontWeight="SemiBold" Width="200"/>
                                        <TextBlock Text=" — " Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding CostoBase, StringFormat=Bs. {0:N2}}"
                                                   Foreground="{StaticResource ColorSuccess}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="➕ Agregar Servicio" Command="{Binding AgregarServicioCommand}" Style="{StaticResource BtnPrimary}"/>
                            <Button Content="✏️ Editar Servicio"   Command="{Binding EditarServicioCommand}"  Style="{StaticResource BtnGhost}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Mantenimiento -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🛠️ Mantenimiento del Sistema" Style="{StaticResource SectionTitle}" FontSize="16"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="🗑️ Limpiar Logs"          Command="{Binding LimpiarLogsCommand}"      Style="{StaticResource BtnGhost}"/>
                            <Button Content="📊 Ver Estadísticas"       Command="{Binding VerEstadisticasCommand}"  Style="{StaticResource BtnPrimary}"/>
                            <Button Content="⚠️ Reiniciar Base de Datos" Command="{Binding ReiniciarBDCommand}"     Style="{StaticResource BtnDanger}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Info del sistema -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="ℹ️ Información del Sistema" Style="{StaticResource SectionTitle}" FontSize="16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Versión:"            Foreground="{StaticResource TextMuted}"    Margin="0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="1.0.0"               Foreground="{StaticResource TextPrimary}"  Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Base de Datos:"      Foreground="{StaticResource TextMuted}"    Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="TallerMecanico"      Foreground="{StaticResource TextPrimary}"  Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Último Respaldo:"    Foreground="{StaticResource TextMuted}"    Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UltimoRespaldo, StringFormat=dd/MM/yyyy HH:mm}"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Total de Registros:" Foreground="{StaticResource TextMuted}"    Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TotalRegistros}"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,4"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
