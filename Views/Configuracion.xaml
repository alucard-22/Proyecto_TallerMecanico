<Page x:Class="Proyecto_taller.Views.Configuracion"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Configuración"
      Background="{StaticResource BgPrimary}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="⚙️  Configuración del Sistema"
                           Style="{StaticResource PageTitle}" FontSize="26"/>
                <TextBlock Text="Gestiona la información del taller y parámetros del sistema"
                           Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="2">

                <!-- ── Información del Taller ── -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🏢  Información del Taller"
                                   Style="{StaticResource SectionTitle}" FontSize="16"/>

                        <TextBlock Text="Nombre del Taller:" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding NombreTaller, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,0"/>

                        <TextBlock Text="Dirección:" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding DireccionTaller, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,0"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Teléfono:" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding TelefonoTaller, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Email:" Style="{StaticResource FormLabel}"/>
                                <TextBox Text="{Binding EmailTaller, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="NIT:" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding NITTaller, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,16"/>

                        <Button Content="💾  Guardar Información"
                                Command="{Binding GuardarInformacionCommand}"
                                Style="{StaticResource BtnPrimary}"
                                HorizontalAlignment="Left" Margin="0"/>
                    </StackPanel>
                </Border>

                <!-- ── Facturación ── -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="📄  Configuración de Facturación"
                                   Style="{StaticResource SectionTitle}" FontSize="16"/>

                        <TextBlock Text="Descuento Máximo (%):" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding DescuentoMaximo, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <CheckBox Content="Solicitar NIT en todas las facturas"
                                  IsChecked="{Binding SolicitarNIT}"
                                  Margin="0,0,0,16"/>

                        <Button Content="💾  Guardar Facturación"
                                Command="{Binding GuardarFacturacionCommand}"
                                Style="{StaticResource BtnPrimary}"
                                HorizontalAlignment="Left" Margin="0"/>
                    </StackPanel>
                </Border>

                <!-- ── Base de Datos ── -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🗄️  Base de Datos"
                                   Style="{StaticResource SectionTitle}" FontSize="16"/>

                        <TextBlock Text="Cadena de Conexión:" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,4"
                                 TextWrapping="Wrap"/>

                        <TextBlock Text="⚠️  Cambiar esta cadena no modifica appsettings.json. Reinicia la aplicación para que tome efecto."
                                   Foreground="{StaticResource ColorWarning}"
                                   FontSize="10" TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Button Content="🔄  Probar Conexión"
                                        Command="{Binding ProbarConexionCommand}"
                                        Style="{StaticResource BtnGhost}"/>
                                <Button Content="📦  Respaldar BD"
                                        Command="{Binding RespaldarBDCommand}"
                                        Style="{StaticResource BtnPrimary}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBlock Text="Último respaldo: "
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding UltimoRespaldo, StringFormat=dd/MM/yyyy HH:mm}"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Servicios ── -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="⚙️  Gestión de Servicios"
                                   Style="{StaticResource SectionTitle}" FontSize="16"/>

                        <ListBox x:Name="lstServicios"
                                 ItemsSource="{Binding Servicios}"
                                 SelectedItem="{Binding ServicioSeleccionado}"
                                 Height="160"
                                 Background="{StaticResource BgInput}"
                                 BorderBrush="{StaticResource BorderColor}"
                                 BorderThickness="1"
                                 Margin="0,0,0,12">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Nombre}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding Categoria}"
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontSize="11"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CostoBase, StringFormat=Bs. {0:N2}}"
                                                   Foreground="{StaticResource ColorSuccess}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="➕  Agregar"
                                    Command="{Binding AgregarServicioCommand}"
                                    Style="{StaticResource BtnPrimary}"/>
                            <Button Content="✏️  Editar"
                                    Command="{Binding EditarServicioCommand}"
                                    Style="{StaticResource BtnGhost}"/>
                            <Button Content="🗑️  Eliminar"
                                    Command="{Binding EliminarServicioCommand}"
                                    Style="{StaticResource BtnDanger}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Mantenimiento ── -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🛠️  Mantenimiento del Sistema"
                                   Style="{StaticResource SectionTitle}" FontSize="16"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="🗑️  Limpiar Logs"
                                    Command="{Binding LimpiarLogsCommand}"
                                    Style="{StaticResource BtnGhost}"/>
                            <Button Content="📊  Ver Estadísticas"
                                    Command="{Binding VerEstadisticasCommand}"
                                    Style="{StaticResource BtnPrimary}"/>
                            <Button Content="⚠️  Reiniciar BD"
                                    Command="{Binding ReiniciarBDCommand}"
                                    Style="{StaticResource BtnDanger}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Info del sistema ── -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="ℹ️  Información del Sistema"
                                   Style="{StaticResource SectionTitle}" FontSize="16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Versión:"
                                       Foreground="{StaticResource TextMuted}" Margin="0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="1.0.0"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Base de Datos:"
                                       Foreground="{StaticResource TextMuted}" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="TallerMecanico"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Último Respaldo:"
                                       Foreground="{StaticResource TextMuted}" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding UltimoRespaldo, StringFormat=dd/MM/yyyy HH:mm}"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,4"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Total Registros:"
                                       Foreground="{StaticResource TextMuted}" Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding TotalRegistros}"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,4"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
