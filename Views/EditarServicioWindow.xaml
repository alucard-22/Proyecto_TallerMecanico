<Window x:Class="Proyecto_taller.Views.EditarServicioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Servicio"
        Height="460" Width="480"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource BgSurface}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgCard}" Padding="22,16">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="txtTitulo"
                               Text="⚙️  Editar Servicio"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Modifica los datos del servicio"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Content="✕" Click="Cancelar_Click"
                        Background="Transparent" Foreground="{StaticResource TextMuted}"
                        BorderThickness="0" FontSize="16" Cursor="Hand"
                        Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22,18,22,10">

                <TextBlock Text="Nombre del servicio: *" Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="txtNombre" Margin="0,0,0,4"/>

                <TextBlock Text="Descripción:" Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="txtDescripcion"
                         Height="60" AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,4"/>

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Categoría: *" Style="{StaticResource FormLabel}"/>
                        <ComboBox x:Name="cmbCategoria">
                            <ComboBoxItem Content="Mecánica"/>
                            <ComboBoxItem Content="Chapería"/>
                            <ComboBoxItem Content="Pintura"/>
                            <ComboBoxItem Content="Electricidad"/>
                            <ComboBoxItem Content="Mantenimiento"/>
                            <ComboBoxItem Content="Diagnóstico"/>
                            <ComboBoxItem Content="Otro"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Costo Base (Bs.): *" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="txtCosto"/>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource BgCard}" Padding="22,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="✕  Cancelar" Click="Cancelar_Click" Style="{StaticResource BtnDanger}"/>
                <Button Content="💾  Guardar"  Click="Guardar_Click"  Style="{StaticResource BtnSuccess}" Padding="20,9"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
