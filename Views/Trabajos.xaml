<Page x:Class="Proyecto_taller.Views.Trabajos"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Módulo de Trabajos"
      Background="{StaticResource BgPrimary}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header / Toolbar ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,14,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6366F1" Offset="0"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🛠️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Gestión de Trabajos" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="Administra órdenes de servicio y reparaciones"
                                   Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Botones de acción -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,0">
                    <!-- Grupo izquierdo: CRUD básico -->
                    <Button Content="🔄  Actualizar"
                            Command="{Binding CargarTrabajosCommand}"
                            Style="{StaticResource BtnSecondary}"/>
                    <Button Content="➕  Nuevo Trabajo"
                            Command="{Binding NuevoTrabajoCommand}"
                            Style="{StaticResource BtnPrimary}"/>

                    <!-- Separador visual -->
                    <Border Width="1" Background="{StaticResource BorderColor}"
                            Margin="8,4" Opacity="0.5"/>

                    <!-- Grupo centro: operaciones del trabajo seleccionado -->
                    <Button Content="📋  Ver Detalles"
                            Command="{Binding VerDetallesCommand}"
                            Style="{StaticResource BtnGhost}"
                            ToolTip="Ver cliente, vehículo, servicios y resumen del trabajo"/>
                    <Button Content="🔧  Gestionar Trabajo"
                            Command="{Binding GestionarCommand}"
                            Style="{StaticResource BtnWarning}"
                            ToolTip="Agregar/quitar servicios, repuestos y modificar precio"/>

                    <!-- Separador visual -->
                    <Border Width="1" Background="{StaticResource BorderColor}"
                            Margin="8,4" Opacity="0.5"/>

                    <!-- Grupo derecho: ciclo de vida -->
                    <Button Content="✅  Finalizar Trabajo"
                            Command="{Binding FinalizarCommand}"
                            Style="{StaticResource BtnSuccess}"
                            ToolTip="Calcular precio final, aplicar descuento y cerrar el trabajo"/>
                    <Button Content="🗑️  Eliminar"
                            Command="{Binding EliminarCommand}"
                            Style="{StaticResource BtnDanger}"/>
                </StackPanel>

                <!-- Filtros por estado -->
                <Border Grid.Row="4" Background="{StaticResource BgCard}"
                        CornerRadius="6" Padding="14,9">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Estado:"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <RadioButton Content="📋  Todos"
                                     IsChecked="{Binding FiltroTodos}"
                                     GroupName="FiltroTrab" VerticalAlignment="Center"/>
                        <RadioButton Content="⏳  Pendientes"
                                     IsChecked="{Binding FiltroPendientes}"
                                     GroupName="FiltroTrab" VerticalAlignment="Center"/>
                        <RadioButton Content="🔄  En Progreso"
                                     IsChecked="{Binding FiltroEnProgreso}"
                                     GroupName="FiltroTrab" VerticalAlignment="Center"/>
                        <RadioButton Content="✅  Finalizados"
                                     IsChecked="{Binding FiltroFinalizados}"
                                     GroupName="FiltroTrab" VerticalAlignment="Center"/>


                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── DataGrid ── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurface}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1">

            <DataGrid x:Name="dgTrabajos"
                      ItemsSource="{Binding Trabajos}"
                      SelectedItem="{Binding TrabajoSeleccionado}"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      MouseDoubleClick="dgTrabajos_MouseDoubleClick"
                      Margin="0">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                <Setter Property="Background" Value="{StaticResource RowPending}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="En Progreso">
                                <Setter Property="Background" Value="{StaticResource RowInProgress}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="Finalizado">
                                <Setter Property="Background" Value="{StaticResource RowDone}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <!-- ID -->
                    <DataGridTextColumn Header="ID" Binding="{Binding TrabajoID}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Estado con badge de color -->
                    <DataGridTemplateColumn Header="Estado" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="badge" CornerRadius="12" Padding="10,3"
                                        HorizontalAlignment="Left" Margin="6,0">
                                    <TextBlock x:Name="txtEstado"
                                               Text="{Binding Estado}"
                                               FontSize="11" FontWeight="SemiBold"/>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#312E6B"/>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                        <Setter TargetName="badge"    Property="Background" Value="#3D2E18"/>
                                        <Setter TargetName="txtEstado" Property="Foreground" Value="#F59E0B"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Estado}" Value="En Progreso">
                                        <Setter TargetName="badge"    Property="Background" Value="#1A2535"/>
                                        <Setter TargetName="txtEstado" Property="Foreground" Value="#3B82F6"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Estado}" Value="Finalizado">
                                        <Setter TargetName="badge"    Property="Background" Value="#182820"/>
                                        <Setter TargetName="txtEstado" Property="Foreground" Value="#10B981"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Cliente -->
                    <DataGridTextColumn Header="Cliente" Width="140">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0} {1}">
                                <Binding Path="Vehiculo.Cliente.Nombre"/>
                                <Binding Path="Vehiculo.Cliente.Apellido"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Vehículo -->
                    <DataGridTextColumn Header="Vehículo" Width="150">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0} {1} ({2})">
                                <Binding Path="Vehiculo.Marca"/>
                                <Binding Path="Vehiculo.Modelo"/>
                                <Binding Path="Vehiculo.Placa"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="FontSize"   Value="12"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Tipo y Descripción -->
                    <DataGridTextColumn Header="Tipo"        Binding="{Binding TipoTrabajo}"  Width="110"/>
                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}"  Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Fechas -->
                    <DataGridTextColumn Header="Ingreso"
                                        Binding="{Binding FechaIngreso, StringFormat=dd/MM/yyyy}"
                                        Width="95">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                <Setter Property="FontSize"   Value="11"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Entrega"
                                        Binding="{Binding FechaEntrega, StringFormat=dd/MM/yyyy}"
                                        Width="95">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                <Setter Property="FontSize"   Value="11"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Precio estimado -->
                    <DataGridTextColumn Header="Estimado"
                                        Binding="{Binding PrecioEstimado, StringFormat=Bs. {0:N2}}"
                                        Width="105">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Precio final (solo si está finalizado) -->
                    <DataGridTextColumn Header="Final"
                                        Binding="{Binding PrecioFinal, StringFormat=Bs. {0:N2}}"
                                        Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#6EE7B7"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
