<Page x:Class="Proyecto_taller.Views.Facturacion"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Módulo de Facturación"
      Background="{StaticResource BgPrimary}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header / Toolbar ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título + stats -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="8" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="💰" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Gestión de Facturación" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Historial y control de facturas emitidas"
                                       Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Border Background="#182820" CornerRadius="8" Padding="14,8" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💰 Facturado: " Foreground="#6EE7B7" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{Binding TotalFacturado, StringFormat=Bs. {0:N2}}"
                                           Foreground="#6EE7B7" FontWeight="Bold" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource AccentMuted}" CornerRadius="8" Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📄 Facturas: " Foreground="{StaticResource AccentLight}"
                                           FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text="{Binding TotalFacturas}"
                                           Foreground="{StaticResource AccentLight}" FontWeight="Bold" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Botones -->
                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button Content="🔄 Actualizar"   Command="{Binding CargarFacturasCommand}"   Style="{StaticResource BtnSecondary}"/>
                    <Button Content="➕ Nueva Factura" Command="{Binding NuevaFacturaCommand}"     Style="{StaticResource BtnPrimary}"/>
                    <Button Content="👁️ Ver Detalle"   Command="{Binding VerDetalleCommand}"      Style="{StaticResource BtnGhost}"/>
                    <Button Content="🖨️ Imprimir"      Command="{Binding ImprimirFacturaCommand}" Style="{StaticResource BtnGhost}"/>
                    <Button Content="❌ Anular"         Command="{Binding AnularFacturaCommand}"   Style="{StaticResource BtnWarning}"/>
                    <Button Content="🗑️ Eliminar"       Command="{Binding EliminarFacturaCommand}" Style="{StaticResource BtnDanger}"/>
                </StackPanel>

                <!-- Filtros -->
                <StackPanel Grid.Row="4" Orientation="Horizontal">
                    <TextBlock Text="Filtrar:"
                               Foreground="{StaticResource TextSecondary}"
                               FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <RadioButton Content="Todas"      IsChecked="{Binding FiltroTodas}"     GroupName="FiltroFact" VerticalAlignment="Center"/>
                    <RadioButton Content="Pagadas"    IsChecked="{Binding FiltroPagadas}"   GroupName="FiltroFact" VerticalAlignment="Center"/>
                    <RadioButton Content="Pendientes" IsChecked="{Binding FiltroPendientes}" GroupName="FiltroFact" VerticalAlignment="Center"/>
                    <RadioButton Content="Este Mes"   IsChecked="{Binding FiltroEsteMes}"   GroupName="FiltroFact" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── DataGrid ── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurface}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1">
            <DataGrid ItemsSource="{Binding Facturas}"
                      SelectedItem="{Binding FacturaSeleccionada}"
                      Margin="0">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                <Setter Property="Background" Value="{StaticResource RowPending}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="Anulada">
                                <Setter Property="Background" Value="{StaticResource RowCancelled}"/>
                                <Setter Property="Opacity"    Value="0.6"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"        Binding="{Binding FacturaID}"  Width="60" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Nº Factura" Binding="{Binding NumeroFactura}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Fecha"    Binding="{Binding FechaEmision, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Cliente"  Binding="{Binding Trabajo.Vehiculo.Cliente.Nombre}"       Width="*"/>
                    <DataGridTextColumn Header="Vehículo" Binding="{Binding Trabajo.Vehiculo.Marca}"                Width="100"/>
                    <DataGridTextColumn Header="Placa"    Binding="{Binding Trabajo.Vehiculo.Placa}"                Width="95"/>
                    <DataGridTextColumn Header="Subtotal"
                                        Binding="{Binding Subtotal, StringFormat=Bs. {0:N2}}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Descuento"
                                        Binding="{Binding Descuento, StringFormat=Bs. {0:N2}}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Total"
                                        Binding="{Binding Total, StringFormat=Bs. {0:N2}}"
                                        Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#6EE7B7"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
