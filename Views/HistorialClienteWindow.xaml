<Window x:Class="Proyecto_taller.Views.HistorialClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historial del Cliente"
        Height="640" Width="920"
        MinHeight="460" MinWidth="680"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270"
                              ShadowDepth="8" BlurRadius="28" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- KPIs -->
                <RowDefinition Height="*"/>
                <!-- Contenido tabbed -->
                <RowDefinition Height="Auto"/>
                <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgCard}"
                    CornerRadius="11,11,0,0"
                    Padding="24,16">
                <Grid>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="44" Height="44" CornerRadius="10"
                                    Margin="0,0,14,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#6366F1" Offset="0"/>
                                        <GradientStop Color="#8B5CF6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="👤" FontSize="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="txtNombreCliente"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="20" FontWeight="Bold"/>
                                <TextBlock x:Name="txtInfoCliente"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="12" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="✕" Click="Cerrar_Click"
                            Background="Transparent"
                            Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" FontSize="18"
                            Cursor="Hand" Padding="10,4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- ── KPIs ── -->
            <Grid Grid.Row="1" Margin="20,14,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource BgCard}"
                        CornerRadius="8" Padding="14,10"
                        Margin="0,0,6,0"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Vehículos registrados"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11"/>
                        <TextBlock x:Name="txtTotalVehiculos"
                                   Foreground="{StaticResource AccentLight}"
                                   FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{StaticResource BgCard}"
                        CornerRadius="8" Padding="14,10"
                        Margin="3,0"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total trabajos"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11"/>
                        <TextBlock x:Name="txtTotalTrabajos"
                                   Foreground="{StaticResource ColorInfo}"
                                   FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="{StaticResource BgCard}"
                        CornerRadius="8" Padding="14,10"
                        Margin="3,0"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total facturado"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11"/>
                        <TextBlock x:Name="txtTotalFacturado"
                                   Foreground="#6EE7B7"
                                   FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        Background="{StaticResource BgCard}"
                        CornerRadius="8" Padding="14,10"
                        Margin="6,0,0,0"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Trabajos activos"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11"/>
                        <TextBlock x:Name="txtTrabajosActivos"
                                   FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Contenido con tabs ── -->
            <Grid Grid.Row="2" Margin="20,14,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab buttons -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="btnTabVehiculos"
                            Content="🚗  Vehículos"
                            Click="TabVehiculos_Click"
                            Style="{StaticResource BtnPrimary}"
                            Padding="18,8" Margin="0,0,6,0"/>
                    <Button x:Name="btnTabTrabajos"
                            Content="🔧  Historial de Trabajos"
                            Click="TabTrabajos_Click"
                            Style="{StaticResource BtnSecondary}"
                            Padding="18,8" Margin="0,0,6,0"/>
                    <TextBlock x:Name="txtTipDoble"
                               Text="Doble clic en una fila para ver detalles"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Panel Vehículos -->
                <Border x:Name="panelVehiculos"
                        Grid.Row="1"
                        Background="{StaticResource BgSurface}"
                        CornerRadius="10"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1">
                    <DataGrid x:Name="dgVehiculos"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="None"
                              MouseDoubleClick="DgVehiculos_DoubleClick"
                              Margin="0">
                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding VehiculoID}"
                                                Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground"
                                                Value="{StaticResource AccentLight}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Placa"
                                                Binding="{Binding Placa}"
                                                Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                        <Setter Property="Foreground"
                                                Value="{StaticResource AccentLight}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Marca"
                                                Binding="{Binding Marca}"
                                                Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Modelo"
                                                Binding="{Binding Modelo}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Año"
                                                Binding="{Binding Anio}"
                                                Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground"
                                                Value="{StaticResource TextSecondary}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Total trabajos"
                                                Binding="{Binding Trabajos.Count}"
                                                Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground"
                                                Value="{StaticResource ColorInfo}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Panel Trabajos -->
                <Border x:Name="panelTrabajos"
                        Grid.Row="1"
                        Visibility="Collapsed"
                        Background="{StaticResource BgSurface}"
                        CornerRadius="10"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1">
                    <DataGrid x:Name="dgTrabajos"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="None"
                              MouseDoubleClick="DgTrabajos_DoubleClick"
                              Margin="0">

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow"
                                   BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                        <Setter Property="Background"
                                                Value="{StaticResource RowPending}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Estado}" Value="En Progreso">
                                        <Setter Property="Background"
                                                Value="{StaticResource RowInProgress}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Estado}" Value="Finalizado">
                                        <Setter Property="Background"
                                                Value="{StaticResource RowDone}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding TrabajoID}"
                                                Width="60">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground"
                                                Value="{StaticResource AccentLight}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Badge de estado -->
                            <DataGridTemplateColumn Header="Estado" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="badge"
                                                CornerRadius="12" Padding="10,3"
                                                HorizontalAlignment="Left"
                                                Margin="6,0">
                                            <TextBlock x:Name="txtEstado"
                                                       Text="{Binding Estado}"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                                <Setter TargetName="badge"    Property="Background" Value="#3D2E18"/>
                                                <Setter TargetName="txtEstado" Property="Foreground" Value="#F59E0B"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Estado}" Value="En Progreso">
                                                <Setter TargetName="badge"    Property="Background" Value="#1A2535"/>
                                                <Setter TargetName="txtEstado" Property="Foreground" Value="#3B82F6"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Estado}" Value="Finalizado">
                                                <Setter TargetName="badge"    Property="Background" Value="#182820"/>
                                                <Setter TargetName="txtEstado" Property="Foreground" Value="#10B981"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Vehículo (Placa)" Width="160">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding StringFormat="{}{0} {1}  ({2})">
                                        <Binding Path="Vehiculo.Marca"/>
                                        <Binding Path="Vehiculo.Modelo"/>
                                        <Binding Path="Vehiculo.Placa"/>
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Tipo"
                                                Binding="{Binding TipoTrabajo}"
                                                Width="110"/>

                            <DataGridTextColumn Header="Descripción"
                                                Binding="{Binding Descripcion}"
                                                Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource TextSecondary}"/>
                                        <Setter Property="TextTrimming"
                                                Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Ingreso"
                                                Binding="{Binding FechaIngreso, StringFormat=dd/MM/yyyy}"
                                                Width="95">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource TextMuted}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Entrega"
                                                Binding="{Binding FechaEntrega, StringFormat=dd/MM/yyyy}"
                                                Width="95">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"
                                                Value="{StaticResource TextMuted}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Precio Final"
                                                Binding="{Binding PrecioFinal, StringFormat=Bs. {0:N2}}"
                                                Width="115">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#6EE7B7"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- ── Footer ── -->
            <Border Grid.Row="3"
                    Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11"
                    Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✕  Cerrar"
                            Click="Cerrar_Click"
                            Style="{StaticResource BtnSecondary}"
                            Width="120"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
