<Window x:Class="Proyecto_taller.Views.EditarVehiculoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vehículo"
        Height="480" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270"
                              ShadowDepth="6" BlurRadius="24" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgCard}"
                    CornerRadius="11,11,0,0"
                    Padding="22,16">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="txtTitulo"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="17" FontWeight="Bold"/>
                        <TextBlock Text="Todos los campos marcados con * son obligatorios"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="Cancelar_Click"
                            Background="Transparent"
                            Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" FontSize="16"
                            Cursor="Hand" Padding="8,4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- Formulario -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="22,16">
                <StackPanel>

                    <!-- Cliente propietario -->
                    <TextBlock Text="Cliente propietario: *"
                               Style="{StaticResource FormLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Buscador de cliente -->
                        <Border Grid.Column="0"
                                Background="{StaticResource BgInput}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="12" VerticalAlignment="Center"
                                           Margin="10,0,6,0" Opacity="0.6"/>
                                <TextBox Grid.Column="1"
                                         x:Name="txtBuscarCliente"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="4,9"
                                         TextChanged="TxtBuscarCliente_Changed"/>
                            </Grid>
                        </Border>

                        <Button Grid.Column="2"
                                Content="✕ Quitar"
                                Click="QuitarCliente_Click"
                                Style="{StaticResource BtnGhost}"
                                Padding="10,8"
                                x:Name="btnQuitarCliente"
                                Visibility="Collapsed"/>
                    </Grid>

                    <!-- Resultados búsqueda cliente -->
                    <Border x:Name="panelResultados"
                            Visibility="Collapsed"
                            Background="{StaticResource BgInput}"
                            BorderBrush="{StaticResource AccentPrimary}"
                            BorderThickness="1" CornerRadius="6"
                            MaxHeight="140" Margin="0,4,0,0">
                        <ListBox x:Name="lstClientes"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 SelectionChanged="LstClientes_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,4">
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="13">
                                            <Run Text="{Binding Nombre}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Apellido}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Telefono}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontFamily="Consolas"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Badge de cliente seleccionado -->
                    <Border x:Name="panelClienteSeleccionado"
                            Visibility="Collapsed"
                            Background="#182820"
                            BorderBrush="{StaticResource ColorSuccess}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="12,9" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="✅  Cliente seleccionado"
                                       Foreground="{StaticResource ColorSuccess}"
                                       FontSize="10" FontWeight="Bold"
                                       Margin="0,0,0,3"/>
                            <TextBlock x:Name="txtClienteSeleccionado"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- Datos del vehículo -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Marca: *"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtMarca" MaxLength="80"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Modelo: *"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtModelo" MaxLength="80"/>
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Placa: *"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtPlaca" MaxLength="20"
                                     CharacterCasing="Upper"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Año:"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtAnio" MaxLength="4"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✕  Cancelar"
                            Click="Cancelar_Click"
                            Style="{StaticResource BtnDanger}"/>
                    <Button Content="💾  Guardar Vehículo"
                            Click="Guardar_Click"
                            Style="{StaticResource BtnSuccess}"
                            Padding="18,9"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
