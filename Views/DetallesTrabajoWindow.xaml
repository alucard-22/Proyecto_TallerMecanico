<Window x:Class="Proyecto_taller.Views.DetallesTrabajoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalles del Trabajo"
        Height="780" Width="860"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Margin"       Value="0,0,0,12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="16,14"/>
            <Setter Property="Margin"          Value="0,0,0,12"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="8" BlurRadius="32" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Border Grid.Row="0" Background="{StaticResource BgCard}"
                    CornerRadius="11,11,0,0" Padding="24,16">
                <Grid>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtTituloHeader"
                                       Text="📋 Detalles del Trabajo"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="18" FontWeight="Bold"/>
                            <Border x:Name="badgeEstado"
                                    CornerRadius="12" Padding="12,3" Margin="14,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="txtEstadoBadge"
                                           FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="txtSubheader"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="Cerrar_Click"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" FontSize="18" Cursor="Hand"
                            Padding="10,4" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- ── Contenido ── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,18">
                <StackPanel>

                    <!-- Fila 1: Cliente + Vehículo -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Cliente -->
                        <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="28" Height="28" CornerRadius="6"
                                            Background="{StaticResource AccentMuted}" Margin="0,0,8,0">
                                        <TextBlock Text="👤" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="CLIENTE"
                                               Foreground="{StaticResource AccentLight}"
                                               FontSize="11" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Nombre:" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtClienteNombre" Style="{StaticResource FieldValue}" FontWeight="SemiBold"/>

                                <TextBlock Text="Teléfono:" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtClienteTelefono" Style="{StaticResource FieldValue}" FontFamily="Consolas"/>

                                <TextBlock Text="Email:" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtClienteEmail" Style="{StaticResource FieldValue}"
                                           Foreground="{StaticResource TextSecondary}" Margin="0"/>
                            </StackPanel>
                        </Border>

                        <!-- Vehículo -->
                        <Border Grid.Column="2" Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="28" Height="28" CornerRadius="6"
                                            Background="#1A2535" Margin="0,0,8,0">
                                        <TextBlock Text="🚗" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="VEHÍCULO"
                                               Foreground="{StaticResource ColorInfo}"
                                               FontSize="11" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Vehículo:" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtVehiculoNombre" Style="{StaticResource FieldValue}" FontWeight="SemiBold"/>

                                <TextBlock Text="Placa:" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtVehiculoPlaca" Style="{StaticResource FieldValue}"
                                           FontFamily="Consolas" Foreground="{StaticResource AccentLight}"/>

                                <TextBlock Text="Año:" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtVehiculoAnio" Style="{StaticResource FieldValue}"
                                           Foreground="{StaticResource TextSecondary}" Margin="0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Trabajo: info general -->
                    <Border Style="{StaticResource SectionCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="28" Height="28" CornerRadius="6"
                                            Background="#2D2010" Margin="0,0,8,0">
                                        <TextBlock Text="🔧" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="TRABAJO"
                                               Foreground="{StaticResource ColorWarning}"
                                               FontSize="11" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Tipo:" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtTipoTrabajo" Style="{StaticResource FieldValue}"/>
                                <TextBlock Text="Descripción:" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtDescripcion" Style="{StaticResource FieldValue}"
                                           Foreground="{StaticResource TextSecondary}" Margin="0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text=" " Margin="0,0,0,40"/>
                                <TextBlock Text="Fecha Ingreso:" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtFechaIngreso" Style="{StaticResource FieldValue}"/>
                                <TextBlock Text="Fecha Entrega Estimada:" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtFechaEntrega" Style="{StaticResource FieldValue}" Margin="0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text=" " Margin="0,0,0,40"/>
                                <TextBlock Text="Precio Estimado:" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtPrecioEstimado"
                                           Style="{StaticResource FieldValue}"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="Precio Final:" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txtPrecioFinal"
                                           Style="{StaticResource FieldValue}"
                                           FontWeight="Bold" FontSize="16"
                                           Foreground="#6EE7B7" Margin="0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Servicios -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="28" Height="28" CornerRadius="6"
                                        Background="{StaticResource AccentMuted}" Margin="0,0,8,0">
                                    <TextBlock Text="⚙️" FontSize="14"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="SERVICIOS REALIZADOS"
                                           Foreground="{StaticResource AccentLight}"
                                           FontSize="11" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtTotalServicios"
                                           Foreground="#6EE7B7" FontWeight="Bold" FontSize="13"
                                           Margin="16,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <DataGrid x:Name="dgServicios"
                                      IsReadOnly="True" AutoGenerateColumns="False"
                                      MaxHeight="160" Background="Transparent"
                                      BorderThickness="0" GridLinesVisibility="None"
                                      HeadersVisibility="Column" RowHeight="38"
                                      ColumnHeaderHeight="34">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Servicio"  Binding="{Binding NombreServicio}" Width="*"/>
                                    <DataGridTextColumn Header="Cant."     Binding="{Binding Cantidad}"       Width="60">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Subtotal"  Binding="{Binding Subtotal, StringFormat=Bs. {0:N2}}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Repuestos -->
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="28" Height="28" CornerRadius="6"
                                        Background="#182820" Margin="0,0,8,0">
                                    <TextBlock Text="📦" FontSize="14"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="REPUESTOS UTILIZADOS"
                                           Foreground="{StaticResource ColorSuccess}"
                                           FontSize="11" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtTotalRepuestos"
                                           Foreground="#6EE7B7" FontWeight="Bold" FontSize="13"
                                           Margin="16,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <DataGrid x:Name="dgRepuestos"
                                      IsReadOnly="True" AutoGenerateColumns="False"
                                      MaxHeight="160" Background="Transparent"
                                      BorderThickness="0" GridLinesVisibility="None"
                                      HeadersVisibility="Column" RowHeight="38"
                                      ColumnHeaderHeight="34">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Repuesto"  Binding="{Binding NombreRepuesto}" Width="*"/>
                                    <DataGridTextColumn Header="Cant."     Binding="{Binding Cantidad}"       Width="60">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="P. Unit."  Binding="{Binding PrecioUnitario, StringFormat=Bs. {0:N2}}" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Subtotal"  Binding="{Binding Subtotal, StringFormat=Bs. {0:N2}}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Foreground" Value="{StaticResource ColorSuccess}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Resumen financiero (visible si hay precio final) -->
                    <Border x:Name="panelResumenFinanciero"
                            Background="#182820"
                            BorderBrush="{StaticResource ColorSuccess}"
                            BorderThickness="1" CornerRadius="8" Padding="20,14"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="RESUMEN FINANCIERO"
                                           Foreground="{StaticResource ColorSuccess}"
                                           FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="Subtotal servicios:" Foreground="{StaticResource TextMuted}" Width="180"/>
                                    <TextBlock x:Name="txtResumenServicios" Foreground="{StaticResource TextSecondary}" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="Subtotal repuestos:"  Foreground="{StaticResource TextMuted}" Width="180"/>
                                    <TextBlock x:Name="txtResumenRepuestos" Foreground="{StaticResource TextSecondary}" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="Ajuste manual:"       Foreground="{StaticResource TextMuted}" Width="180"/>
                                    <TextBlock x:Name="txtResumenAjuste"   Foreground="{StaticResource TextSecondary}" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="Descuento aplicado:"  Foreground="{StaticResource TextMuted}" Width="180"/>
                                    <TextBlock x:Name="txtResumenDescuento" Foreground="{StaticResource ColorDanger}" FontFamily="Consolas"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="TOTAL FINAL"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11" FontWeight="Bold"
                                           HorizontalAlignment="Right"/>
                                <TextBlock x:Name="txtResumenTotal"
                                           Foreground="#6EE7B7"
                                           FontSize="28" FontWeight="Bold"
                                           FontFamily="Consolas"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ── Footer ── -->
            <Border Grid.Row="2" Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11" Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✕  Cerrar" Click="Cerrar_Click"
                            Style="{StaticResource BtnSecondary}" Width="120"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
