<Window x:Class="Proyecto_taller.Views.EditarClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Cliente"
        Height="480" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270"
                              ShadowDepth="6" BlurRadius="24" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgCard}"
                    CornerRadius="11,11,0,0"
                    Padding="22,16">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="txtTitulo"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="17" FontWeight="Bold"/>
                        <TextBlock Text="Modifica los datos del cliente"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="Cancelar_Click"
                            Background="Transparent"
                            Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" FontSize="16"
                            Cursor="Hand" Padding="8,4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- Formulario -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="22,16">
                <StackPanel>

                    <!-- ID (solo lectura) -->
                    <TextBlock Text="ID de cliente:"
                               Style="{StaticResource FormLabel}"/>
                    <Border Background="{StaticResource BgInput}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="10,9" Margin="0,0,0,4">
                        <TextBlock x:Name="txtClienteId"
                                   Foreground="{StaticResource TextMuted}"
                                   FontFamily="Consolas" FontSize="13"/>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nombre: *"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtNombre" MaxLength="100"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Apellido: *"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtApellido" MaxLength="100"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Teléfono / WhatsApp: *"
                               Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtTelefono" MaxLength="20"/>

                    <TextBlock Text="Correo electrónico:"
                               Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtCorreo" MaxLength="150"/>

                    <TextBlock Text="Dirección:"
                               Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtDireccion"
                             MaxLength="250"
                             Height="60"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Fecha de registro:"
                               Style="{StaticResource FormLabel}"/>
                    <Border Background="{StaticResource BgInput}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="10,9" Margin="0,0,0,4">
                        <TextBlock x:Name="txtFechaRegistro"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="13"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✕  Cancelar"
                            Click="Cancelar_Click"
                            Style="{StaticResource BtnDanger}"/>
                    <Button Content="💾  Guardar Cambios"
                            Click="Guardar_Click"
                            Style="{StaticResource BtnSuccess}"
                            Padding="18,9"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>