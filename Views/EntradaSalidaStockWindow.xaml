<Window x:Class="Proyecto_taller.Views.EntradaSalidaStockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Movimiento de Stock"
        Height="420" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border x:Name="rootBorder"
            Background="{StaticResource BgSurface}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="6"
                              BlurRadius="24" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    x:Name="headerBorder"
                    CornerRadius="11,11,0,0"
                    Padding="22,16">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="txtTitulo"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="17" FontWeight="Bold"/>
                        <TextBlock x:Name="txtRepuestoNombre"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="Cancelar_Click"
                            Background="Transparent"
                            Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" FontSize="16" Cursor="Hand"
                            Padding="8,4"
                            HorizontalAlignment="Right" VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- Formulario -->
            <StackPanel Grid.Row="1" Margin="22,18,22,10">

                <!-- Info del repuesto actual -->
                <Border x:Name="infoPanel"
                        CornerRadius="8" Padding="14,12"
                        Margin="0,0,0,16"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Stock actual"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11"/>
                            <TextBlock x:Name="txtStockActual"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Stock mínimo"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11"/>
                            <TextBlock x:Name="txtStockMinimo"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Precio unitario"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11"/>
                            <TextBlock x:Name="txtPrecioUnitario"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource ColorSuccess}"
                                       VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Cantidad -->
                <TextBlock Text="Cantidad a mover: *"
                           Style="{StaticResource FormLabel}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnMenos"
                            Grid.Column="0"
                            Content="−"
                            Click="BtnMenos_Click"
                            Width="38" Height="38"
                            FontSize="18"
                            Style="{StaticResource BtnSecondary}"
                            Margin="0,0,6,0"/>
                    <TextBox x:Name="txtCantidad"
                             Grid.Column="1"
                             Text="1"
                             FontSize="18"
                             FontWeight="Bold"
                             TextAlignment="Center"
                             VerticalContentAlignment="Center"
                             Height="38"
                             TextChanged="TxtCantidad_Changed"/>
                    <Button x:Name="btnMas"
                            Grid.Column="2"
                            Content="+"
                            Click="BtnMas_Click"
                            Width="38" Height="38"
                            FontSize="16"
                            Style="{StaticResource BtnSecondary}"
                            Margin="6,0,0,0"/>
                </Grid>

                <!-- Motivo / Nota -->
                <TextBlock Text="Motivo / observación (opcional):"
                           Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="txtMotivo"
                         Height="60"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Resultado proyectado -->
                <Border x:Name="resultadoPanel"
                        CornerRadius="8" Padding="14,10"
                        Margin="0,14,0,0"
                        BorderThickness="1">
                    <Grid>
                        <TextBlock Text="Stock resultante:"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtStockResultante"
                                   FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✕  Cancelar"
                            Click="Cancelar_Click"
                            Style="{StaticResource BtnSecondary}"/>
                    <Button x:Name="btnConfirmar"
                            Click="Confirmar_Click"
                            Style="{StaticResource BtnSuccess}"
                            Padding="20,9"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
