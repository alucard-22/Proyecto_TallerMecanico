<Window x:Class="Proyecto_taller.Views.CancelarReservaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cancelar Reserva"
        Height="290" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgPrimary}">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource ColorDanger}"
            BorderThickness="1" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="18" Opacity="0.45"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="#2D1A1A"
                    CornerRadius="9,9,0,0"
                    Padding="20,14">
                <TextBlock Text="❌  Cancelar Reserva"
                           Foreground="{StaticResource ColorDanger}"
                           FontSize="15" FontWeight="Bold"/>
            </Border>

            <!-- Form -->
            <StackPanel Grid.Row="1" Margin="20,18,20,10">
                <TextBlock Text="¿Por qué se cancela la reserva?"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="13" FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Motivo de cancelación:"
                           Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="txtMotivo"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="72"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,12"/>

                <CheckBox x:Name="chkNoShow"
                          Content="El cliente no se presentó (No Show)"
                          Foreground="{StaticResource ColorDanger}"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgCard}"
                    CornerRadius="0,0,9,9"
                    Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Volver"
                            Click="BtnVolver_Click"
                            Style="{StaticResource BtnGhost}"/>
                    <Button Content="Cancelar Reserva"
                            Click="BtnConfirmar_Click"
                            Style="{StaticResource BtnDanger}"
                            Padding="16,9"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
