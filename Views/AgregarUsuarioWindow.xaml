<Window x:Class="Proyecto_taller.Views.AgregarUsuarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agregar Nuevo Usuario"
        Height="500" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1" CornerRadius="12"
            MouseDown="Border_MouseDown">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="6" BlurRadius="24" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource BgCard}"
                    CornerRadius="11,11,0,0" Padding="20,16">
                <Grid>
                    <TextBlock Text="👤  Agregar Nuevo Usuario"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="✕" Click="CloseButton_Click"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" FontSize="16" Cursor="Hand"
                            Padding="8,4" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,18">
                <StackPanel>
                    <TextBlock Text="Nombre de Usuario *" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtNombreUsuario"/>

                    <TextBlock Text="Nombre Completo *" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtNombreCompleto"/>

                    <TextBlock Text="Contraseña *" Style="{StaticResource FormLabel}"/>
                    <PasswordBox x:Name="txtPassword"/>

                    <TextBlock Text="Confirmar Contraseña *" Style="{StaticResource FormLabel}"/>
                    <PasswordBox x:Name="txtConfirmarPassword"/>

                    <TextBlock Text="Rol *" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="cmbRol" SelectedIndex="1"
                  SelectionChanged="CmbRol_SelectionChanged">
                        <ComboBoxItem Content="Administrador"/>
                        <ComboBoxItem Content="Empleado"/>
                    </ComboBox>

                    <CheckBox x:Name="chkActivo"
                  Content="Usuario activo"
                  IsChecked="True"
                  Margin="0,12,0,0"/>

                    <!-- Panel de permisos (visible solo para Empleado) -->
                    <Border x:Name="panelPermisos"
                Background="{StaticResource BgCard}"
                CornerRadius="8" Padding="16,14"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                Margin="0,14,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="🔐  PERMISOS DE MÓDULOS"
                               Foreground="{StaticResource AccentLight}"
                               FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="Selecciona los módulos a los que tendrá acceso este empleado:"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="11" TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                            <!-- Botones rápidos -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="✅ Todos"
                            Click="SeleccionarTodos_Click"
                            Style="{StaticResource BtnGhost}"
                            Padding="10,5" Margin="0,0,6,0" FontSize="11"/>
                                <Button Content="☐ Ninguno"
                            Click="SeleccionarNinguno_Click"
                            Style="{StaticResource BtnGhost}"
                            Padding="10,5" FontSize="11"/>
                            </StackPanel>

                            <!-- Grid de checkboxes 2 columnas -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <CheckBox x:Name="chkInicio"
                              Grid.Row="0" Grid.Column="0"
                              Content="🏠  Inicio"
                              IsChecked="True"
                              IsEnabled="False"
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,5"/>

                                <CheckBox x:Name="chkClientes"
                              Grid.Row="0" Grid.Column="1"
                              Content="👥  Clientes"
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,5"/>

                                <CheckBox x:Name="chkVehiculos"
                              Grid.Row="1" Grid.Column="0"
                              Content="🚗  Vehículos"
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,5"/>

                                <CheckBox x:Name="chkTrabajos"
                              Grid.Row="1" Grid.Column="1"
                              Content="🛠️  Trabajos"
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,5"/>

                                <CheckBox x:Name="chkReservas"
                              Grid.Row="2" Grid.Column="0"
                              Content="📅  Reservas"
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,5"/>

                                <CheckBox x:Name="chkInventario"
                              Grid.Row="2" Grid.Column="1"
                              Content="📦  Inventario"
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,5"/>

                                <CheckBox x:Name="chkRecibos"
                              Grid.Row="3" Grid.Column="0"
                              Content="💰  Recibos"
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,5"/>

                                <CheckBox x:Name="chkReportes"
                              Grid.Row="3" Grid.Column="1"
                              Content="📊  Reportes"
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,5"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource AccentMuted}"
                CornerRadius="6" Padding="12,10" Margin="0,14,0,0">
                        <TextBlock Foreground="{StaticResource AccentLight}"
                       FontSize="11" TextWrapping="Wrap">
                <Run Text="ℹ️ "/>
                <Run Text="Los Administradores tienen acceso completo a todos los módulos automáticamente."/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11" Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✕ Cancelar"       Click="CloseButton_Click"      Style="{StaticResource BtnDanger}"/>
                    <Button Content="✅ Guardar Usuario" Click="GuardarButton_Click"    Style="{StaticResource BtnSuccess}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
