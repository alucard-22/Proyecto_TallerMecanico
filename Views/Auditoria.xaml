<Page x:Class="Proyecto_taller.Views.Auditoria"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Auditoría del Sistema"
      Background="{StaticResource BgPrimary}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header / Filtros ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título + total -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="8" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🛡️" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Auditoría del Sistema" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Quién hizo qué y cuándo — solo lectura"
                                       Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource AccentMuted}"
                            CornerRadius="20" Padding="14,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Registros: " Foreground="{StaticResource AccentLight}"
                                       FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Text="{Binding TotalRegistros}"
                                       Foreground="{StaticResource AccentLight}"
                                       FontWeight="Bold" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Filtros -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Usuario:"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Usuarios}"
                              SelectedItem="{Binding UsuarioFiltro}"
                              DisplayMemberPath="NombreCompleto"/>

                    <TextBlock Grid.Column="3" Text="Acción:"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                    <ComboBox Grid.Column="4"
                              ItemsSource="{Binding AccionesDisponibles}"
                              SelectedItem="{Binding AccionFiltro}"/>

                    <TextBlock Grid.Column="6" Text="Desde:"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                    <DatePicker Grid.Column="7" SelectedDate="{Binding FechaInicio}"/>

                    <TextBlock Grid.Column="9" Text="Hasta:"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                    <DatePicker Grid.Column="10" SelectedDate="{Binding FechaFin}"/>

                    <Button Grid.Column="12" Content="✕ Limpiar filtros"
                            Command="{Binding LimpiarFiltrosCommand}"
                            Style="{StaticResource BtnGhost}"
                            Padding="12,7" HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ── DataGrid de auditoría ── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurface}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1">
            <DataGrid ItemsSource="{Binding Registros}"
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      GridLinesVisibility="None"
                      Margin="0">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Accion}" Value="Eliminar">
                                <Setter Property="Background" Value="{StaticResource RowCancelled}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Accion}" Value="Reiniciar BD">
                                <Setter Property="Background" Value="#3D1A1A"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Accion}" Value="Finalizar">
                                <Setter Property="Background" Value="{StaticResource RowDone}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Fecha"
                                        Binding="{Binding Fecha, StringFormat='dd/MM/yyyy HH:mm:ss'}"
                                        Width="155">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                <Setter Property="FontSize" Value="12"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Usuario"
                                        Binding="{Binding NombreUsuario}"
                                        Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Acción" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="badge" CornerRadius="10" Padding="8,3"
                                        HorizontalAlignment="Left" Margin="4,0"
                                        Background="{StaticResource AccentMuted}">
                                    <TextBlock x:Name="txtAccion" Text="{Binding Accion}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentLight}"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Accion}" Value="Eliminar">
                                        <Setter TargetName="badge" Property="Background" Value="#3D1A1A"/>
                                        <Setter TargetName="txtAccion" Property="Foreground" Value="#FCA5A5"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Accion}" Value="Reiniciar BD">
                                        <Setter TargetName="badge" Property="Background" Value="#3D1A1A"/>
                                        <Setter TargetName="txtAccion" Property="Foreground" Value="#EF4444"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Accion}" Value="Crear">
                                        <Setter TargetName="badge" Property="Background" Value="#182820"/>
                                        <Setter TargetName="txtAccion" Property="Foreground" Value="#10B981"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Accion}" Value="Finalizar">
                                        <Setter TargetName="badge" Property="Background" Value="#182820"/>
                                        <Setter TargetName="txtAccion" Property="Foreground" Value="#10B981"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Accion}" Value="Login">
                                        <Setter TargetName="badge" Property="Background" Value="#1A2535"/>
                                        <Setter TargetName="txtAccion" Property="Foreground" Value="#3B82F6"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Entidad"
                                        Binding="{Binding Entidad}"
                                        Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding EntidadID}"
                                        Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Detalle"
                                        Binding="{Binding Detalle}"
                                        Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
