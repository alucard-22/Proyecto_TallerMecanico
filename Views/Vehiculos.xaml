<Page x:Class="Proyecto_taller.Views.Vehiculos"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Módulo de Vehículos"
      Background="{StaticResource BgPrimary}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header / Toolbar ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="8" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🚗" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Gestión de Vehículos" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Administra la flota de vehículos registrados"
                                       Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource AccentMuted}"
                            CornerRadius="20" Padding="14,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Total: " Foreground="{StaticResource AccentLight}"
                                       FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Text="{Binding Vehiculos.Count}"
                                       Foreground="{StaticResource AccentLight}"
                                       FontWeight="Bold" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Búsqueda -->
                <Border Grid.Row="2"
                        Background="{StaticResource BgInput}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="12,0,6,0" Opacity="0.5"
                                   Foreground="{StaticResource TextSecondary}"/>
                        <TextBox Grid.Column="1" x:Name="txtBuscar"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="4,10"
                                 TextChanged="TxtBuscar_TextChanged"/>
                    </Grid>
                </Border>

                <!-- Botones -->
                <StackPanel Grid.Row="4" Orientation="Horizontal">
                    <Button Content="🔄 Actualizar"    Command="{Binding CargarVehiculosCommand}"  Style="{StaticResource BtnSecondary}"/>
                    <Button Content="➕ Nuevo Vehículo" Command="{Binding AgregarVehiculoCommand}"  Style="{StaticResource BtnPrimary}"/>
                    <Button Content="✏️ Editar"         Command="{Binding EditarVehiculoCommand}"   Style="{StaticResource BtnGhost}"/>
                    <Button Content="🗑️ Eliminar"       Command="{Binding EliminarVehiculoCommand}" Style="{StaticResource BtnDanger}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── DataGrid ── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurface}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1">
            <DataGrid x:Name="dgVehiculos"
                      ItemsSource="{Binding Vehiculos}"
                      SelectedItem="{Binding VehiculoSeleccionado}"
                      Margin="0" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding VehiculoID}" Width="65" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Placa" Binding="{Binding Placa}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Marca"   Binding="{Binding Marca}"           Width="*"/>
                    <DataGridTextColumn Header="Modelo"  Binding="{Binding Modelo}"          Width="*"/>
                    <DataGridTextColumn Header="Año"     Binding="{Binding Anio}"            Width="75"/>
                    <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente.Nombre}"  Width="*"/>
                    <DataGridTextColumn Header="Apellido" Binding="{Binding Cliente.Apellido}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
