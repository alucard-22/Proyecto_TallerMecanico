<Page x:Class="Proyecto_taller.Views.Vehiculos"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:Proyecto_taller.Helpers"
      Title="Módulo de Vehículos"
      Background="{StaticResource BgPrimary}">

    <Page.Resources>
        <helpers:StringToVisibilityConverter x:Key="StrToVis"/>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header / Toolbar ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título + badge total -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="8"
                                Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🚗" FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Gestión de Vehículos"
                                       Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Administra la flota y consulta el historial de trabajos"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource AccentMuted}"
                            CornerRadius="20" Padding="14,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Total: "
                                       Foreground="{StaticResource AccentLight}"
                                       FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock Text="{Binding TotalVehiculos}"
                                       Foreground="{StaticResource AccentLight}"
                                       FontWeight="Bold" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Barra de búsqueda -->
                <Border Grid.Row="2"
                        Background="{StaticResource BgInput}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="12,0,6,0" Opacity="0.5"
                                   Foreground="{StaticResource TextSecondary}"/>
                        <TextBox Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="4,10"
                                 Text="{Binding TextoBusqueda,
                                        UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2"
                                Content="✕"
                                Command="{Binding LimpiarBusquedaCommand}"
                                Background="Transparent"
                                Foreground="{StaticResource TextMuted}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Padding="10,0"
                                FontSize="13"
                                Visibility="{Binding TextoBusqueda,
                                             Converter={StaticResource StrToVis}}"/>
                    </Grid>
                </Border>

                <!-- Botones de acción -->
                <StackPanel Grid.Row="4" Orientation="Horizontal">
                    <Button Content="🔄  Actualizar"
                            Command="{Binding CargarVehiculosCommand}"
                            Style="{StaticResource BtnSecondary}"/>
                    <Button Content="➕  Nuevo Vehículo"
                            Command="{Binding AgregarVehiculoCommand}"
                            Style="{StaticResource BtnPrimary}"/>
                    <Button Content="✏️  Editar"
                            Command="{Binding EditarVehiculoCommand}"
                            Style="{StaticResource BtnGhost}"/>

                    <Border Width="1" Background="{StaticResource BorderColor}"
                            Margin="8,4" Opacity="0.5"/>

                    <Button Content="📋  Ver Historial"
                            Command="{Binding VerHistorialCommand}"
                            Style="{StaticResource BtnSuccess}"
                            ToolTip="Ver todos los trabajos realizados a este vehículo"/>

                    <Border Width="1" Background="{StaticResource BorderColor}"
                            Margin="8,4" Opacity="0.5"/>

                    <Button Content="🗑️  Eliminar"
                            Command="{Binding EliminarVehiculoCommand}"
                            Style="{StaticResource BtnDanger}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── DataGrid ── -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurface}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1">
            <DataGrid x:Name="dgVehiculos"
                      ItemsSource="{Binding Vehiculos}"
                      SelectedItem="{Binding VehiculoSeleccionado}"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      MouseDoubleClick="DgVehiculos_DoubleClick"
                      Margin="0">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding VehiculoID}"
                                        Width="65" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource AccentLight}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Placa"
                                        Binding="{Binding Placa}"
                                        Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource AccentLight}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Marca"
                                        Binding="{Binding Marca}"
                                        Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Modelo"
                                        Binding="{Binding Modelo}"
                                        Width="130"/>

                    <DataGridTextColumn Header="Año"
                                        Binding="{Binding Anio}"
                                        Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource TextSecondary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- FIX: columna cliente combinada en lugar de Nombre y Apellido separados -->
                    <DataGridTextColumn Header="Propietario"
                                        Width="*">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0} {1}">
                                <Binding Path="Cliente.Nombre"/>
                                <Binding Path="Cliente.Apellido"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Teléfono"
                                        Binding="{Binding Cliente.Telefono}"
                                        Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource TextSecondary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
