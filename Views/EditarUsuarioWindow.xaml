<Window x:Class="Proyecto_taller.Views.EditarUsuarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Usuario"
        Height="620"
        MinHeight="620"
        Width="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1"
            CornerRadius="12"
            MouseDown="Border_MouseDown">

        <Border.Effect>
            <DropShadowEffect Color="Black"
                              Direction="270"
                              ShadowDepth="6"
                              BlurRadius="24"
                              Opacity="0.5"/>
        </Border.Effect>

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgCard}"
                    CornerRadius="11,11,0,0"
                    Padding="22,16">

                <Grid>

                    <StackPanel>

                        <TextBlock x:Name="txtTitulo"
                                   Text="✏️ Editar Usuario"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="17"
                                   FontWeight="Bold"/>

                        <TextBlock x:Name="txtSubtitulo"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11"
                                   Margin="0,4,0,0"/>

                    </StackPanel>

                    <Button Content="✕"
                            Click="Cancelar_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource TextMuted}"
                            FontSize="16"
                            Cursor="Hand"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"/>

                </Grid>

            </Border>

            <!-- CONTENIDO -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel Margin="22,18,22,20">

                    <!-- Usuario -->
                    <TextBlock Text="Nombre de usuario (no editable):"
                               Style="{StaticResource FormLabel}"/>

                    <Border Background="{StaticResource BgInput}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,9"
                            Margin="0,0,0,12">

                        <TextBlock x:Name="txtNombreUsuario"
                                   Foreground="{StaticResource TextMuted}"
                                   FontFamily="Consolas"
                                   FontSize="13"/>

                    </Border>

                    <!-- Nombre -->
                    <TextBlock Text="Nombre completo:"
                               Style="{StaticResource FormLabel}"/>

                    <TextBox x:Name="txtNombreCompleto"
                             MaxLength="100"
                             Margin="0,0,0,12"/>

                    <!-- Rol -->
                    <TextBlock Text="Rol:"
                               Style="{StaticResource FormLabel}"/>

                    <ComboBox x:Name="cmbRol"
                              Margin="0,0,0,12"
                              SelectionChanged="CmbRol_SelectionChanged">

                        <ComboBoxItem Content="Administrador"
                                      Tag="Administrador"/>

                        <ComboBoxItem Content="Empleado"
                                      Tag="Empleado"/>

                    </ComboBox>

                    <!-- PERMISOS -->
                    <Border x:Name="panelPermisos"
                            Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,14">

                        <StackPanel>

                            <TextBlock Text="🔐 PERMISOS DE MÓDULOS"
                                       Foreground="{StaticResource AccentLight}"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,10">

                                <Button Content="✅ Todos"
                                        Click="SeleccionarTodos_Click"
                                        Style="{StaticResource BtnGhost}"
                                        Margin="0,0,8,0"/>

                                <Button Content="☐ Ninguno"
                                        Click="SeleccionarNinguno_Click"
                                        Style="{StaticResource BtnGhost}"/>

                            </StackPanel>

                            <UniformGrid Columns="2">

                                <CheckBox x:Name="chkInicio"
                                          Content="🏠 Inicio"
                                          IsChecked="True"
                                          IsEnabled="False"/>

                                <CheckBox x:Name="chkClientes"
                                          Content="👥 Clientes"/>

                                <CheckBox x:Name="chkVehiculos"
                                          Content="🚗 Vehículos"/>

                                <CheckBox x:Name="chkTrabajos"
                                          Content="🛠 Trabajos"/>

                                <CheckBox x:Name="chkReservas"
                                          Content="📅 Reservas"/>

                                <CheckBox x:Name="chkInventario"
                                          Content="📦 Inventario"/>

                                <CheckBox x:Name="chkRecibos"
                                          Content="💰 Recibos"/>

                                <CheckBox x:Name="chkReportes"
                                          Content="📊 Reportes"/>

                            </UniformGrid>

                        </StackPanel>

                    </Border>

                    <!-- INFO -->
                    <Border Background="{StaticResource AccentMuted}"
                            CornerRadius="6"
                            Padding="12">

                        <TextBlock
                            Foreground="{StaticResource AccentLight}"
                            TextWrapping="Wrap">

                            ℹ️ Para cambiar la contraseña utilice el botón
                            "Cambiar Contraseña" del módulo de usuarios.

                        </TextBlock>

                    </Border>

                </StackPanel>

            </ScrollViewer>

            <!-- FOOTER -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11"
                    Padding="22,14">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="✕ Cancelar"
                            Click="Cancelar_Click"
                            Style="{StaticResource BtnDanger}"
                            Margin="0,0,10,0"/>

                    <Button Content="💾 Guardar Cambios"
                            Click="Guardar_Click"
                            Style="{StaticResource BtnSuccess}"
                            Padding="16,9"/>

                </StackPanel>

            </Border>

        </Grid>

    </Border>

</Window>