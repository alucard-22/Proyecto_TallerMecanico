<Window x:Class="Proyecto_taller.Views.CambiarPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cambiar Contraseña"
        Height="360" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <!-- Sin Window.Resources: se usan los estilos globales de App.xaml
         FIX: la versión anterior definía FormLabel, SubmitButton y CancelButton
         con colores hardcodeados que rompían el tema oscuro del resto de la app. -->

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270"
                              ShadowDepth="6" BlurRadius="24" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgCard}"
                    CornerRadius="11,11,0,0"
                    Padding="22,16">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="🔒  Cambiar Contraseña"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="17" FontWeight="Bold"/>
                        <TextBlock x:Name="txtUsuarioInfo"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕"
                            Click="CloseButton_Click"
                            Background="Transparent"
                            Foreground="{StaticResource TextMuted}"
                            BorderThickness="0"
                            FontSize="16" Cursor="Hand"
                            Padding="8,4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- Formulario -->
            <StackPanel Grid.Row="1" Margin="22,18,22,10">

                <TextBlock Text="Nueva contraseña: *"
                           Style="{StaticResource FormLabel}"/>
                <PasswordBox x:Name="txtNuevaPassword"/>

                <TextBlock Text="Confirmar contraseña: *"
                           Style="{StaticResource FormLabel}"/>
                <PasswordBox x:Name="txtConfirmarPassword"/>

                <!-- Requisitos -->
                <Border Background="{StaticResource AccentMuted}"
                        CornerRadius="6" Padding="12,9"
                        Margin="0,14,0,0">
                    <TextBlock Foreground="{StaticResource AccentLight}"
                               FontSize="11" TextWrapping="Wrap">
                        <Run Text="ℹ️  "/>
                        <Run Text="La contraseña debe tener al menos 6 caracteres."/>
                    </TextBlock>
                </Border>

            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11"
                    Padding="22,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✕  Cancelar"
                            Click="CloseButton_Click"
                            Style="{StaticResource BtnDanger}"/>
                    <Button Content="✅  Cambiar Contraseña"
                            Click="GuardarButton_Click"
                            Style="{StaticResource BtnSuccess}"
                            Padding="18,9"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
