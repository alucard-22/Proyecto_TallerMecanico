<Window x:Class="Proyecto_taller.Views.GestionarTrabajoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestionar Trabajo"
        Height="680" Width="1100"
        MinHeight="520" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="8" BlurRadius="32" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource BgCard}"
                    CornerRadius="11,11,0,0" Padding="24,16">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="txtTitulo"
                                   Text="🔧 Gestionar Trabajo"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="18" FontWeight="Bold"/>
                        <TextBlock x:Name="txtSubtitulo"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="Cancelar_Click"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" FontSize="18" Cursor="Hand"
                            Padding="10,4" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- Contenido en 3 columnas -->
            <Grid Grid.Row="1" Margin="18,16,18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- ── Columna 1: SERVICIOS ── -->
                <Border Grid.Column="0" Background="{StaticResource BgCard}"
                        CornerRadius="10" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="⚙️  SERVICIOS DISPONIBLES"
                                   Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="1" x:Name="txtBuscarServicio"
                                 Margin="0,0,0,8"
                                 TextChanged="TxtBuscarServicio_TextChanged"/>
                        <DataGrid Grid.Row="2" x:Name="dgServiciosDisponibles"
                                  IsReadOnly="True" SelectionMode="Single"
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Servicio" Binding="{Binding Nombre}"    Width="*"/>
                                <DataGridTextColumn Header="Costo"    Binding="{Binding CostoBase, StringFormat=Bs. {0:N2}}" Width="95">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="3" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,8,0,0">
                            <TextBlock Text="Cant:" Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                            <TextBox x:Name="txtCantidadServicio" Width="50" Text="1" TextAlignment="Center"/>
                            <Button Content="➕ Agregar" Click="AgregarServicio_Click"
                                    Style="{StaticResource BtnSuccess}" Padding="12,7" Margin="8,0,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Row="5" Text="✅  SERVICIOS DEL TRABAJO"
                                   Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                        <DataGrid Grid.Row="6" x:Name="dgServiciosTrabajo"
                                  SelectionMode="Single" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Servicio" Binding="{Binding NombreServicio}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Cant."    Binding="{Binding Cantidad}"       Width="55" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=Bs. {0:N2}}" Width="90" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="36">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕" Click="EliminarServicio_Click"
                                                    Background="Transparent"
                                                    Foreground="{StaticResource ColorDanger}"
                                                    BorderThickness="0" Cursor="Hand"
                                                    FontSize="13" Padding="4,2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- ── Columna 2: REPUESTOS ── -->
                <Border Grid.Column="2" Background="{StaticResource BgCard}"
                        CornerRadius="10" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📦  REPUESTOS DISPONIBLES"
                                   Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="1" x:Name="txtBuscarRepuesto"
                                 Margin="0,0,0,8"
                                 TextChanged="TxtBuscarRepuesto_TextChanged"/>
                        <DataGrid Grid.Row="2" x:Name="dgRepuestosDisponibles"
                                  IsReadOnly="True" SelectionMode="Single"
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Repuesto" Binding="{Binding Nombre}"       Width="*"/>
                                <DataGridTextColumn Header="Stock"    Binding="{Binding StockActual}"  Width="55">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Precio"   Binding="{Binding PrecioUnitario, StringFormat=Bs. {0:N2}}" Width="95">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="3" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,8,0,0">
                            <TextBlock Text="Cant:" Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                            <TextBox x:Name="txtCantidadRepuesto" Width="50" Text="1" TextAlignment="Center"/>
                            <Button Content="➕ Agregar" Click="AgregarRepuesto_Click"
                                    Style="{StaticResource BtnSuccess}" Padding="12,7" Margin="8,0,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Row="5" Text="✅  REPUESTOS DEL TRABAJO"
                                   Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>
                        <DataGrid Grid.Row="6" x:Name="dgRepuestosTrabajo"
                                  SelectionMode="Single" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Repuesto"  Binding="{Binding NombreRepuesto}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Cant."     Binding="{Binding Cantidad}"       Width="50" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="P.Unit"    Binding="{Binding PrecioUnitario, StringFormat=Bs. {0:N2}}" Width="80" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Subtotal"  Binding="{Binding Subtotal, StringFormat=Bs. {0:N2}}" Width="85" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="{StaticResource ColorSuccess}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="36">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕" Click="EliminarRepuesto_Click"
                                                    Background="Transparent"
                                                    Foreground="{StaticResource ColorDanger}"
                                                    BorderThickness="0" Cursor="Hand"
                                                    FontSize="13" Padding="4,2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- ── Columna 3: RESUMEN + PRECIO MANUAL ── -->
                <Border Grid.Column="4" Background="{StaticResource BgCard}"
                        CornerRadius="10" Padding="16">
                    <StackPanel>
                        <TextBlock Text="💰  RESUMEN"
                                   Style="{StaticResource SectionTitle}"/>

                        <!-- Totales en vivo -->
                        <Border Background="{StaticResource BgInput}" CornerRadius="6"
                                Padding="12,10" Margin="0,4,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Servicios:" Foreground="{StaticResource TextMuted}"
                                               Width="90" FontSize="12"/>
                                    <TextBlock x:Name="lblTotalServicios"
                                               Foreground="{StaticResource AccentLight}"
                                               FontWeight="Bold" FontSize="13" FontFamily="Consolas"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Repuestos:" Foreground="{StaticResource TextMuted}"
                                               Width="90" FontSize="12"/>
                                    <TextBlock x:Name="lblTotalRepuestos"
                                               Foreground="{StaticResource ColorSuccess}"
                                               FontWeight="Bold" FontSize="13" FontFamily="Consolas"/>
                                </StackPanel>
                                <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,4,0,6" Opacity="0.5"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Subtotal:" Foreground="{StaticResource TextSecondary}"
                                               Width="90" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock x:Name="lblSubtotal"
                                               Foreground="{StaticResource ColorWarning}"
                                               FontWeight="Bold" FontSize="14" FontFamily="Consolas"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Precio manual override -->
                        <TextBlock Text="💵  PRECIO FINAL MANUAL"
                                   Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>
                        <TextBlock Text="Deja vacío para usar el subtotal calculado arriba."
                                   Foreground="{StaticResource TextMuted}" FontSize="10"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtPrecioManual"
                                 TextChanged="TxtPrecioManual_TextChanged"/>

                        <Border Background="{StaticResource BgInput}" CornerRadius="6"
                                Padding="10,8" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Precio a guardar:"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="lblPrecioAGuardar"
                                           Foreground="{StaticResource ColorWarning}"
                                           FontWeight="Bold" FontSize="15" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>

                        <!-- Estado del trabajo -->
                        <TextBlock Text="📌  ESTADO"
                                   Style="{StaticResource SectionTitle}" Margin="0,16,0,6"/>
                        <ComboBox x:Name="cmbEstado" SelectionChanged="CmbEstado_Changed">
                            <ComboBoxItem Content="⏳  Pendiente"   Tag="Pendiente"/>
                            <ComboBoxItem Content="🔄  En Progreso" Tag="En Progreso"/>
                        </ComboBox>

                        <!-- Fecha estimada de entrega -->
                        <TextBlock Text="📅  ENTREGA ESTIMADA"
                                   Style="{StaticResource SectionTitle}" Margin="0,14,0,6"/>
                        <DatePicker x:Name="dpFechaEntrega"/>

                        <!-- Notas adicionales al trabajo -->
                        <TextBlock Text="📝  NOTAS ADICIONALES"
                                   Style="{StaticResource SectionTitle}" Margin="0,14,0,6"/>
                        <TextBox x:Name="txtNotas"
                                 Height="70"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>

                        <Border Background="{StaticResource AccentMuted}" CornerRadius="6"
                                Padding="10,8" Margin="0,14,0,0">
                            <TextBlock Foreground="{StaticResource AccentLight}"
                                       FontSize="10" TextWrapping="Wrap">
                                <Run Text="ℹ️  "/>
                                <Run Text="Guardar aquí no finaliza el trabajo. Use 'Finalizar Trabajo' para cerrar la orden y calcular el precio final con descuentos."/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11" Padding="20,14">
                <Grid>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="💵 TOTAL ESTIMADO: "
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblTotalFooter"
                                   Foreground="{StaticResource ColorWarning}"
                                   FontWeight="Bold" FontSize="16"
                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button Content="✕  Cancelar" Click="Cancelar_Click"
                                Style="{StaticResource BtnDanger}"/>
                        <Button Content="💾  Guardar Cambios" Click="Guardar_Click"
                                Style="{StaticResource BtnSuccess}" Padding="22,9"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
