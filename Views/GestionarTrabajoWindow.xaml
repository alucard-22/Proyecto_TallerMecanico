<!-- GESTIONAR_TRABAJO_WINDOW.XAML -->
<Window x:Class="Proyecto_taller.Views.GestionarTrabajoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestionar Servicios y Repuestos"
        Height="700" Width="1080"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource AccentPrimary}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="6" BlurRadius="28" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource BgCard}"
                    CornerRadius="11,11,0,0" Padding="22,16">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="txtTituloTrabajo"
                                   Text="🔧 Gestionar Trabajo"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="18" FontWeight="Bold"/>
                        <TextBlock x:Name="txtInfoTrabajo"
                                   Text="Información del trabajo"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="CloseButton_Click"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" FontSize="18" Cursor="Hand"
                            Padding="10,4" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- Content: dos columnas -->
            <Grid Grid.Row="1" Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SERVICIOS -->
                <Border Grid.Column="0" Background="{StaticResource BgCard}"
                        CornerRadius="10" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="🛠️ SERVICIOS DISPONIBLES"
                                   Style="{StaticResource SectionTitle}"/>

                        <TextBox Grid.Row="1" x:Name="txtBuscarServicio"
                                 Margin="0,0,0,10"
                                 TextChanged="TxtBuscarServicio_TextChanged"/>

                        <DataGrid Grid.Row="2" x:Name="dgServiciosDisponibles"
                                  SelectionMode="Single" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Servicio" Binding="{Binding Nombre}"    Width="*"/>
                                <DataGridTextColumn Header="Costo"    Binding="{Binding CostoBase, StringFormat=Bs. {0:N2}}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="3" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,10,0,0">
                            <TextBox x:Name="txtCantidadServicio" Width="55" Text="1"
                                     TextAlignment="Center"/>
                            <Button Content="➕ Agregar Servicio"
                                    Click="AgregarServicio_Click"
                                    Style="{StaticResource BtnSuccess}"/>
                        </StackPanel>

                        <TextBlock Grid.Row="5" Text="✅ SERVICIOS DEL TRABAJO"
                                   Style="{StaticResource SectionTitle}"/>

                        <DataGrid Grid.Row="6" x:Name="dgServiciosTrabajo" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Servicio" Binding="{Binding NombreServicio}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Cant."    Binding="{Binding Cantidad}"       Width="50"/>
                                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=Bs. {0:N2}}" Width="90" IsReadOnly="True"/>
                                <DataGridTemplateColumn Width="36">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑️" Click="EliminarServicio_Click"
                                                    Style="{StaticResource BtnDanger}"
                                                    Padding="4,2" Margin="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- REPUESTOS -->
                <Border Grid.Column="2" Background="{StaticResource BgCard}"
                        CornerRadius="10" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📦 REPUESTOS DISPONIBLES"
                                   Style="{StaticResource SectionTitle}"/>

                        <TextBox Grid.Row="1" x:Name="txtBuscarRepuesto"
                                 Margin="0,0,0,10"
                                 TextChanged="TxtBuscarRepuesto_TextChanged"/>

                        <DataGrid Grid.Row="2" x:Name="dgRepuestosDisponibles"
                                  SelectionMode="Single" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Repuesto" Binding="{Binding Nombre}"       Width="*"/>
                                <DataGridTextColumn Header="Stock"    Binding="{Binding StockActual}"  Width="55"/>
                                <DataGridTextColumn Header="Precio"   Binding="{Binding PrecioUnitario, StringFormat=Bs. {0:N2}}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="3" Orientation="Horizontal"
                                    HorizontalAlignment="Center" Margin="0,10,0,0">
                            <TextBox x:Name="txtCantidadRepuesto" Width="55" Text="1"
                                     TextAlignment="Center"/>
                            <Button Content="➕ Agregar Repuesto"
                                    Click="AgregarRepuesto_Click"
                                    Style="{StaticResource BtnSuccess}"/>
                        </StackPanel>

                        <TextBlock Grid.Row="5" Text="✅ REPUESTOS DEL TRABAJO"
                                   Style="{StaticResource SectionTitle}"/>

                        <DataGrid Grid.Row="6" x:Name="dgRepuestosTrabajo" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Repuesto" Binding="{Binding NombreRepuesto}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Cant."    Binding="{Binding Cantidad}"        Width="50"/>
                                <DataGridTextColumn Header="P.Unit"   Binding="{Binding PrecioUnitario, StringFormat=Bs. {0:N2}}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=Bs. {0:N2}}"       Width="90" IsReadOnly="True"/>
                                <DataGridTemplateColumn Width="36">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑️" Click="EliminarRepuesto_Click"
                                                    Style="{StaticResource BtnDanger}"
                                                    Padding="4,2" Margin="0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer con totales -->
            <Border Grid.Row="2" Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11" Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Background="#182820" CornerRadius="6" Padding="12,7" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💰 Servicios: " Foreground="#6EE7B7" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtTotalServicios" Text="Bs. 0.00" Foreground="#6EE7B7" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource AccentMuted}" CornerRadius="6" Padding="12,7" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦 Repuestos: " Foreground="{StaticResource AccentLight}" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtTotalRepuestos" Text="Bs. 0.00" Foreground="{StaticResource AccentLight}" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#2D2010" CornerRadius="6" Padding="12,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💵 TOTAL: " Foreground="{StaticResource ColorWarning}" FontWeight="Bold"/>
                                <TextBlock x:Name="txtTotalGeneral" Text="Bs. 0.00"
                                           Foreground="{StaticResource ColorWarning}"
                                           FontWeight="Bold" FontSize="15"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="✕ Cancelar"       Click="CloseButton_Click"    Style="{StaticResource BtnDanger}"/>
                        <Button Content="💾 Guardar Cambios" Click="GuardarCambios_Click" Style="{StaticResource BtnSuccess}" Padding="22,9"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
