<Window x:Class="Proyecto_taller.Views.FinalizarTrabajoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Finalizar Trabajo"
        Height="700" Width="680"
        MinHeight="520" MinWidth="580"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border Background="{StaticResource BgSurface}"
            BorderBrush="{StaticResource ColorSuccess}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="8" BlurRadius="32" Opacity="0.55"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header verde -->
            <Border Grid.Row="0" CornerRadius="11,11,0,0" Padding="24,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#182820" Offset="0"/>
                        <GradientStop Color="#1E3628" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="txtTitulo"
                                   Text="✅  Finalizar Trabajo"
                                   Foreground="#6EE7B7"
                                   FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="txtSubtitulo"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="✕" Click="Cancelar_Click"
                            Background="Transparent" Foreground="{StaticResource TextMuted}"
                            BorderThickness="0" FontSize="18" Cursor="Hand"
                            Padding="10,4" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- Contenido -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,18">
                <StackPanel>

                    <!-- Resumen del cliente y trabajo -->
                    <Border Background="{StaticResource BgCard}"
                            CornerRadius="8" Padding="16,14" Margin="0,0,0,14"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CLIENTE / VEHÍCULO"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock x:Name="txtCliente"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtVehiculo"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="12" Margin="0,3,0,0"/>
                                <TextBlock x:Name="txtPlaca"
                                           Foreground="{StaticResource AccentLight}"
                                           FontFamily="Consolas" FontSize="13"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="TRABAJO"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock x:Name="txtTipoTrabajo"
                                           Foreground="{StaticResource ColorWarning}"
                                           FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtDescripcion"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="11" TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                                <TextBlock x:Name="txtFechaIngreso"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Desglose de servicios y repuestos -->
                    <Border Background="{StaticResource BgCard}"
                            CornerRadius="8" Padding="16,14" Margin="0,0,0,14"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="DESGLOSE DEL TRABAJO"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>

                            <!-- Servicios -->
                            <TextBlock Text="⚙️  Servicios"
                                       Foreground="{StaticResource AccentLight}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <DataGrid x:Name="dgServiciosResumen"
                                      IsReadOnly="True" AutoGenerateColumns="False"
                                      MaxHeight="130" Background="Transparent"
                                      BorderThickness="0" GridLinesVisibility="None"
                                      HeadersVisibility="Column" RowHeight="34"
                                      ColumnHeaderHeight="30" Margin="0,0,0,8">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Servicio"  Binding="{Binding NombreServicio}" Width="*"/>
                                    <DataGridTextColumn Header="Cant."     Binding="{Binding Cantidad}"       Width="55">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Subtotal"  Binding="{Binding Subtotal, StringFormat=Bs. {0:N2}}" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Repuestos -->
                            <TextBlock Text="📦  Repuestos"
                                       Foreground="{StaticResource ColorSuccess}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,4,0,6"/>
                            <DataGrid x:Name="dgRepuestosResumen"
                                      IsReadOnly="True" AutoGenerateColumns="False"
                                      MaxHeight="130" Background="Transparent"
                                      BorderThickness="0" GridLinesVisibility="None"
                                      HeadersVisibility="Column" RowHeight="34"
                                      ColumnHeaderHeight="30" Margin="0,0,0,6">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Repuesto"  Binding="{Binding NombreRepuesto}" Width="*"/>
                                    <DataGridTextColumn Header="Cant."     Binding="{Binding Cantidad}"       Width="55">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="P. Unit."  Binding="{Binding PrecioUnitario, StringFormat=Bs. {0:N2}}" Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Subtotal"  Binding="{Binding Subtotal, StringFormat=Bs. {0:N2}}" Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Foreground" Value="{StaticResource ColorSuccess}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Panel de precio y descuento -->
                    <Border Background="{StaticResource BgCard}"
                            CornerRadius="8" Padding="18,16" Margin="0,0,0,14"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="💰  PRECIO FINAL"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="10" FontWeight="Bold" Margin="0,0,0,14"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Precio base calculado -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Subtotal calculado"
                                               Foreground="{StaticResource TextMuted}" FontSize="11"
                                               Margin="0,0,0,4"/>
                                    <Border Background="{StaticResource BgInput}" CornerRadius="6" Padding="12,10">
                                        <TextBlock x:Name="lblSubtotalCalculado"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontFamily="Consolas" FontSize="16" FontWeight="Bold"/>
                                    </Border>

                                    <TextBlock Text="Precio base (editable)"
                                               Foreground="{StaticResource TextMuted}" FontSize="11"
                                               Margin="0,12,0,4"/>
                                    <TextBox x:Name="txtPrecioBase"
                                             FontFamily="Consolas" FontSize="14"
                                             TextChanged="RecalcularTotal"/>
                                </StackPanel>

                                <!-- Descuento -->
                                <StackPanel Grid.Column="2">
                                    <CheckBox x:Name="chkDescuento"
                                              Content="Aplicar descuento"
                                              Foreground="{StaticResource TextPrimary}"
                                              FontSize="13" Margin="0,0,0,10"
                                              Checked="DescuentoToggle" Unchecked="DescuentoToggle"/>

                                    <StackPanel x:Name="panelDescuento" IsEnabled="False" Opacity="0.4">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <RadioButton x:Name="rbPorcentaje"
                                                         Content="% porcentaje"
                                                         IsChecked="True"
                                                         GroupName="TipoDesc"
                                                         Checked="RecalcularTotal"
                                                         FontSize="12"/>
                                            <RadioButton x:Name="rbMonto"
                                                         Content="Bs. monto fijo"
                                                         GroupName="TipoDesc"
                                                         Checked="RecalcularTotal"
                                                         FontSize="12" Margin="10,0,0,0"/>
                                        </StackPanel>

                                        <TextBlock Text="Valor del descuento:"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtDescuento"
                                                 FontFamily="Consolas" FontSize="14"
                                                 Text="0"
                                                 TextChanged="RecalcularTotal"/>
                                        <TextBlock x:Name="lblDescuentoCalc"
                                                   Foreground="{StaticResource ColorDanger}"
                                                   FontSize="12" FontFamily="Consolas"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Total final destacado -->
                            <Border Background="#1A2A1A"
                                    BorderBrush="{StaticResource ColorSuccess}"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="18,14" Margin="0,18,0,0">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="TOTAL A COBRAR"
                                                   Foreground="{StaticResource ColorSuccess}"
                                                   FontSize="11" FontWeight="Bold"/>
                                        <TextBlock x:Name="lblTotalFinal"
                                                   Foreground="#6EE7B7"
                                                   FontSize="32" FontWeight="Bold"
                                                   FontFamily="Consolas"/>
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="Precio base:"
                                                   Foreground="{StaticResource TextMuted}" FontSize="11"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock x:Name="lblResumenBase"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontFamily="Consolas" FontSize="13"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Text="Descuento:"
                                                   Foreground="{StaticResource TextMuted}" FontSize="11"
                                                   HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="lblResumenDescuento"
                                                   Foreground="{StaticResource ColorDanger}"
                                                   FontFamily="Consolas" FontSize="13"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Advertencia de confirmación -->
                    <Border Background="#2D1A1A"
                            BorderBrush="{StaticResource ColorWarning}"
                            BorderThickness="1" CornerRadius="8" Padding="14,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Top"/>
                            <TextBlock Foreground="#FDE68A" FontSize="11" TextWrapping="Wrap">
                                <Run FontWeight="Bold" Text="Al finalizar: "/>
                                <Run Text="el trabajo quedará cerrado, el stock de repuestos se confirmará como descontado y se habilitará la generación de factura. Esta acción no se puede deshacer."/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgCard}"
                    CornerRadius="0,0,11,11" Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✕  Cancelar"
                            Click="Cancelar_Click"
                            Style="{StaticResource BtnDanger}"/>
                    <Button Content="✅  Confirmar y Finalizar Trabajo"
                            Click="Confirmar_Click"
                            Style="{StaticResource BtnSuccess}"
                            Padding="22,10" FontSize="14"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
