<Window x:Class="Proyecto_taller.Views.SeleccionarTrabajoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar Trabajo para Facturar"
        Height="560" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BgSurface}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgCard}" Padding="24,16">
            <StackPanel>
                <TextBlock Text="💰  Nueva Factura — Seleccionar Trabajo"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="17" FontWeight="Bold"/>
                <TextBlock Text="Solo se muestran trabajos finalizados que aún no tienen factura."
                           Foreground="{StaticResource TextMuted}"
                           FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Búsqueda -->
        <Border Grid.Row="1" Padding="20,12,20,0">
            <Border Background="{StaticResource BgInput}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔍"
                               FontSize="12" VerticalAlignment="Center"
                               Margin="10,0,6,0" Foreground="{StaticResource TextMuted}"/>
                    <TextBox Grid.Column="1" x:Name="txtBuscar"
                             Background="Transparent" BorderThickness="0"
                             Padding="4,9"
                             TextChanged="TxtBuscar_Changed"/>
                </Grid>
            </Border>
        </Border>

        <!-- Lista de trabajos -->
        <Border Grid.Row="2" Margin="20,10,20,0"
                Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1" CornerRadius="8">
            <DataGrid x:Name="dgTrabajos"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="None"
                      MouseDoubleClick="DgTrabajos_DoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding TrabajoID}" Width="55">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="👤 Cliente" Width="150">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0} {1}">
                                <Binding Path="Vehiculo.Cliente.Nombre"/>
                                <Binding Path="Vehiculo.Cliente.Apellido"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="📞 Teléfono"
                                        Binding="{Binding Vehiculo.Cliente.Telefono}" Width="115">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="🚗 Vehículo (Placa)" Width="160">
                        <DataGridTextColumn.Binding>
                            <MultiBinding StringFormat="{}{0} {1}  ·  {2}">
                                <Binding Path="Vehiculo.Marca"/>
                                <Binding Path="Vehiculo.Modelo"/>
                                <Binding Path="Vehiculo.Placa"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="12"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="🔧 Tipo" Binding="{Binding TipoTrabajo}" Width="100"/>

                    <DataGridTextColumn Header="📅 Finalizado"
                                        Binding="{Binding FechaEntrega, StringFormat=dd/MM/yyyy}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="💰 Precio Final"
                                        Binding="{Binding PrecioFinal, StringFormat=Bs. {0:N2}}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#6EE7B7"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="{StaticResource BgCard}" Padding="20,14" Margin="0,10,0,0">
            <Grid>
                <TextBlock x:Name="txtContador"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="12" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="✕  Cancelar"
                            Click="Cancelar_Click"
                            Style="{StaticResource BtnSecondary}"/>
                    <Button Content="💾  Facturar Trabajo Seleccionado"
                            Click="Facturar_Click"
                            Style="{StaticResource BtnSuccess}"
                            Padding="20,9"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

