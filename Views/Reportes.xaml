<Page x:Class="Proyecto_taller.Views.Reportes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Módulo de Reportes"
      Background="{StaticResource BgPrimary}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="📊 Reportes y Estadísticas"
                               Style="{StaticResource PageTitle}" FontSize="26"/>
                    <TextBlock Text="Análisis de rendimiento del taller"
                               Foreground="{StaticResource TextMuted}" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="🔄 Actualizar"  Command="{Binding ActualizarReportesCommand}" Style="{StaticResource BtnSecondary}"/>
                    <Button Content="📥 Exportar"    Command="{Binding ExportarExcelCommand}"      Style="{StaticResource BtnSuccess}"/>
                </StackPanel>
            </Grid>

            <!-- Filtros de período -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="📅 Período de Análisis" Style="{StaticResource SectionTitle}" FontSize="15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Inicio:"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                        <DatePicker Grid.Column="1" SelectedDate="{Binding FechaInicio}" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="3" Text="Fin:"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                        <DatePicker Grid.Column="4" SelectedDate="{Binding FechaFin}" Margin="0,0,10,0"/>
                        <Button Grid.Column="6" Content="Aplicar"
                                Command="{Binding AplicarFiltroCommand}"
                                Style="{StaticResource BtnPrimary}" Margin="0"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Hoy"         Command="{Binding FiltroHoyCommand}"    Style="{StaticResource BtnGhost}"/>
                        <Button Content="Esta Semana" Command="{Binding FiltroSemanaCommand}" Style="{StaticResource BtnGhost}"/>
                        <Button Content="Este Mes"    Command="{Binding FiltroMesCommand}"    Style="{StaticResource BtnGhost}"/>
                        <Button Content="Este Año"    Command="{Binding FiltroAnioCommand}"   Style="{StaticResource BtnGhost}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- KPIs -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="💰 Ingresos Totales" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding IngresosTotales, StringFormat=Bs. {0:N2}}"
                                   Foreground="#6EE7B7" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalFacturas}" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        <TextBlock Text="Facturas pagadas" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="🔧 Trabajos Realizados" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding TrabajosRealizados}"
                                   Foreground="{StaticResource AccentLight}" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TrabajosEnProceso}" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        <TextBlock Text="En proceso" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="5,0">
                    <StackPanel>
                        <TextBlock Text="👥 Clientes Atendidos" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding ClientesAtendidos}"
                                   Foreground="{StaticResource ColorInfo}" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ClientesNuevos}" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        <TextBlock Text="Clientes nuevos" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource Card}" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="📦 Repuestos Vendidos" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding RepuestosVendidos}"
                                   Foreground="{StaticResource ColorWarning}" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ValorRepuestos, StringFormat=Bs. {0:N2}}"
                                   Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        <TextBlock Text="Valor total" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Servicios + Distribución trabajos -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Top servicios -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="🏆 Servicios Más Solicitados" Style="{StaticResource SectionTitle}" FontSize="15"/>
                        <DataGrid ItemsSource="{Binding TopServicios}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MaxHeight="320">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Servicio" Binding="{Binding Nombre}" Width="*"/>
                                <DataGridTextColumn Header="Veces"    Binding="{Binding Cantidad}" Width="70"/>
                                <DataGridTextColumn Header="Total"
                                                    Binding="{Binding Total, StringFormat=Bs. {0:N2}}"
                                                    Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Trabajos por estado -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="📈 Trabajos por Estado" Style="{StaticResource SectionTitle}" FontSize="15"/>

                        <!-- Filas de estados -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" Fill="{StaticResource ColorWarning}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Pendientes" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding TrabajosPendientes}"
                                       Foreground="{StaticResource ColorWarning}"
                                       FontSize="20" FontWeight="Bold" Margin="12,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" Fill="{StaticResource ColorInfo}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="En Progreso" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding TrabajosEnProceso}"
                                       Foreground="{StaticResource ColorInfo}"
                                       FontSize="20" FontWeight="Bold" Margin="12,0"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" Fill="{StaticResource ColorSuccess}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Finalizados" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding TrabajosFinalizados}"
                                       Foreground="{StaticResource ColorSuccess}"
                                       FontSize="20" FontWeight="Bold" Margin="12,0"/>
                        </Grid>

                        <!-- Total -->
                        <Border Background="{StaticResource BgCard}" CornerRadius="6" Padding="12,8" Margin="0,0,0,20">
                            <Grid>
                                <TextBlock Text="TOTAL" Foreground="{StaticResource TextSecondary}"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TrabajosRealizados}"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Barras visuales -->
                        <TextBlock Text="Distribución Visual"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12" Margin="0,0,0,10"/>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pendientes"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{StaticResource ColorWarning}"
                                    Height="20" CornerRadius="3"
                                    Width="{Binding BarraPendientes}"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="En Progreso"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{StaticResource ColorInfo}"
                                    Height="20" CornerRadius="3"
                                    Width="{Binding BarraEnProceso}"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Finalizados"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="{StaticResource ColorSuccess}"
                                    Height="20" CornerRadius="3"
                                    Width="{Binding BarraFinalizados}"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
