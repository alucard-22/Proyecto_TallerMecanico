<Window x:Class="Proyecto_taller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Sistema Taller El Choco"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        MinHeight="600"
        MinWidth="1000"
        Background="{StaticResource BgPrimary}">

    <Window.Resources>
        <!-- Botón de menú lateral -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Foreground"             Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="FontSize"               Value="13"/>
            <Setter Property="Margin"                 Value="8,2"/>
            <Setter Property="Height"                 Value="46"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                Value="16,0"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="Cursor"                 Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="{TemplateBinding Margin}">
                            <Grid>
                                <Border x:Name="indicator"
                                        Width="3"
                                        HorizontalAlignment="Left"
                                        CornerRadius="0,2,2,0"
                                        Background="{StaticResource AccentPrimary}"
                                        Opacity="0"/>
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Margin="18,0,12,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BgSurfaceHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="indicator"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.5" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="indicator"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón de menú activo -->
        <Style x:Key="ActiveMenuButton" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#312E6B" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="{TemplateBinding Margin}">
                            <Grid>
                                <Border Width="3"
                                        HorizontalAlignment="Left"
                                        CornerRadius="0,2,2,0"
                                        Background="{StaticResource AccentPrimary}"/>
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Margin="18,0,12,0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón top bar -->
        <Style x:Key="TopBarButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="Width"           Value="36"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BgSurfaceHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgPrimary}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Grid Grid.Column="0" Background="{StaticResource BgSurface}">
            <Grid.Effect>
                <DropShadowEffect Color="Black" Direction="0" ShadowDepth="0" BlurRadius="24" Opacity="0.4"/>
            </Grid.Effect>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo / Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgCard}"
                    Padding="16"
                    Margin="10,10,10,0"
                    CornerRadius="10">
                <StackPanel>
                    <Border Width="52" Height="52" CornerRadius="12"
                            HorizontalAlignment="Center" Margin="0,0,0,10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6366F1" Offset="0"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🔧" FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="TALLER EL CHOCO"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Sistema de Gestión"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="10" HorizontalAlignment="Center"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <!-- Separador -->
            <Border Grid.Row="0" Height="1"
                    Background="{StaticResource BorderColor}"
                    VerticalAlignment="Bottom"
                    Margin="10,0" Opacity="0.4"/>

            <!-- Menú Items -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,14,0,0">
                <StackPanel Margin="6,0">
                    <Button x:Name="BtnInicio"     Content="🏠  Inicio"       Style="{StaticResource MenuButton}" Click="Inicio_Click"/>
                    <Button x:Name="BtnClientes"   Content="👥  Clientes"     Style="{StaticResource MenuButton}" Click="Clientes_Click"/>
                    <Button x:Name="BtnVehiculos"  Content="🚗  Vehículos"    Style="{StaticResource MenuButton}" Click="Vehiculos_Click"/>
                    <Button x:Name="BtnServicios"  Content="🛠️  Trabajos"     Style="{StaticResource MenuButton}" Click="Servicios_Click"/>
                    <Button x:Name="BtnReservas"   Content="📅  Reservas"     Style="{StaticResource MenuButton}" Click="Reservas_Click"/>
                    <Button x:Name="BtnInventario" Content="📦  Inventario"   Style="{StaticResource MenuButton}" Click="Inventario_Click"/>
                    <Button x:Name="BtnFacturacion" Content="💰  Facturación" Style="{StaticResource MenuButton}" Click="Facturacion_Click"/>
                    <Button x:Name="BtnReportes"   Content="📊  Reportes"     Style="{StaticResource MenuButton}" Click="Reportes_Click"/>

                    <Border Height="1" Background="{StaticResource BorderColor}"
                            Margin="12,10" Opacity="0.3"/>

                    <Button x:Name="BtnUsuarios" Content="👤  Usuarios"
                            Style="{StaticResource MenuButton}"
                            Click="Usuarios_Click"
                            Visibility="Collapsed"/>

                    <Button x:Name="BtnCerrarSesion" Content="🚪  Cerrar Sesión"
                            Style="{StaticResource MenuButton}"
                            Click="CerrarSesion_Click"/>

                    <Border Height="1" Background="{StaticResource BorderColor}"
                            Margin="12,10" Opacity="0.3"/>

                    <Button x:Name="BtnConfiguracion" Content="⚙️  Configuración"
                            Style="{StaticResource MenuButton}" Click="Configuracion_Click"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgCard}"
                    Padding="14,10" Margin="10,0,10,10" CornerRadius="10">
                <StackPanel>
                    <Border Height="1" Background="{StaticResource BorderColor}"
                            Margin="0,0,0,10" Opacity="0.3"/>
                    <TextBlock Text="v1.0.0"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                    <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='dd/MM/yyyy'}"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="10" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgSurface}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,0,0,1"
                    Padding="24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleTextBlock"
                                   Text="Bienvenido al Sistema"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SubtitleTextBlock"
                                   Text="Panel de Control Principal"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="👤"
                                Style="{StaticResource TopBarButton}"
                                Margin="4,0"
                                ToolTip="Perfil de Usuario"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Frame de contenido -->
            <Frame x:Name="MainFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="{StaticResource BgPrimary}"/>
        </Grid>
    </Grid>
</Window>
